<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<%- include('partials/shell/head-start', { pageTitle: 'Paperless-AI next Chat' }) %>
    <script src="/vendor/marked/marked.min.js"></script>
    <script src="/vendor/highlight/highlight.min.js"></script>
    <link rel="stylesheet" href="/vendor/highlight/styles/github.min.css">
    <link rel="stylesheet" href="/css/chat.css">
<%- include('partials/shell/head-end') %>
<%- include('partials/shell/body-open', {
    version: typeof version !== 'undefined' ? version : '',
    chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : false,
    ragEnabled: typeof ragEnabled !== 'undefined' ? ragEnabled : false
}) %>
            <div class="content-wrapper">
                <div class="content-header">
                    <div class="content-header-main">
                        <h2 class="content-title">Document Chat</h2>
                    </div>
                </div>

                <div class="chat-container">
                    <!-- Document Selection -->
                    <div class="material-card">
                        <h2 class="card-title">Select Document</h2>
                        <div class="document-search-wrapper">
                            <% const preselectedDocument = (documents && documents.length > 0) ? documents[0] : null; %>
                            <input
                                id="documentSearchInput"
                                class="select-input"
                                type="search"
                                placeholder="Search documents (title, ID, correspondent)..."
                                value="<%= preselectedDocument ? preselectedDocument.title : '' %>"
                                data-open-document-id="<%= open || '' %>"
                                autocomplete="off">
                            <div id="documentSearchResults" class="search-results hidden" role="listbox" aria-label="Document search results"></div>
                            <input type="hidden" id="documentSelect" value="<%= open || '' %>">
                            <p id="documentSearchStatus" class="search-status">Loading recent documents...</p>
                        </div>
                    </div>

                    <!-- Chat Interface -->
                    <div class="material-card chat-interface">
                        <!-- Initial State -->
                        <div class="initial-state" id="initialState">
                            <p>Please select a document to start the chat.</p>
                        </div>

                        <!-- Chat History -->
                        <div id="chatHistory" class="chat-history hidden">
                            <!-- Messages will be added here dynamically -->
                        </div>

                        <!-- Message Input -->
                        <div id="messageForm" class="message-form hidden">
                            <input type="hidden" id="documentId" name="documentId" value="">
                            <textarea 
                                id="messageInput"
                                name="message" 
                                class="message-input"
                                placeholder="Type your message... (Shift + Enter for new line)"
                                rows="1"
                                required></textarea>
                            <button type="submit" class="send-button">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="js/dashboard.js"></script>
    <script src="/js/document-omnibox.js"></script>
    <script src="js/chat.js"></script>
    <%- include('partials/shell/footer') %>
    <%- include('partials/shell/body-close') %>