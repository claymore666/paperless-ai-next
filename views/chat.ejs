<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paperless-AI next Chat</title>
    <link rel="icon" type="image/webp" href="/favicon.webp">
    <script src="/vendor/tailwind/tailwindcss-3.4.16.js"></script>
    <script src="/vendor/marked/marked.min.js"></script>
    <script src="/vendor/highlight/highlight.min.js"></script>
    <link rel="stylesheet" href="/vendor/highlight/styles/github.min.css">
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="css/dashboard.css">
    <link rel="stylesheet" href="css/chat.css">
</head>
<body class="h-full">
    <button id="themeToggle" class="theme-toggle">
        <i class="fas fa-moon"></i>
    </button>

    <div class="layout-container">
        <button id="mobileMenuButton" class="mobile-menu-button">
            <i class="fas fa-bars"></i>
        </button>
        <!-- Sidebar -->
        <div id="sidebarOverlay" class="sidebar-overlay"></div>
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="/favicon.webp" class="no-invert" alt="Paperless AI Logo" style="height: 60px;">
                <h1 class="brand-title"><span class="relative inline-block">Paperless-AI<span class="absolute right-0 top-0 translate-x-1/2 -translate-y-1/2 rotate-12 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-blue-100 text-blue-700">next</span></span><small style="display: block;"><%= version %></small></h1>
            </div>

            <nav class="sidebar-nav">
                <%- include('partials/sidebar-nav', { chatEnabled, ragEnabled }) %>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <div class="content-header">
                    <h2 class="content-title">Document Chat</h2>
                </div>

                <div class="chat-container">
                    <!-- Document Selection -->
                    <div class="material-card">
                        <h2 class="card-title">Select Document</h2>
                        <select id="documentSelect" class="select-input">
                            <option value="">Please choose...</option>
                            <% documents.forEach(function(doc) { %>
                                <option value="<%= doc.id %>" <%= doc.id == open ? 'selected="true"' : '' %>><%= doc.title %></option>
                            <% }); %>
                        </select>
                    </div>

                    <!-- Chat Interface -->
                    <div class="material-card chat-interface">
                        <!-- Initial State -->
                        <div class="initial-state" id="initialState">
                            <p>Please select a document to start the chat.</p>
                        </div>

                        <!-- Chat History -->
                        <div id="chatHistory" class="chat-history hidden">
                            <!-- Messages will be added here dynamically -->
                        </div>

                        <!-- Message Input -->
                        <div id="messageForm" class="message-form hidden">
                            <input type="hidden" id="documentId" name="documentId" value="">
                            <textarea 
                                id="messageInput"
                                name="message" 
                                class="message-input"
                                placeholder="Type your message... (Shift + Enter for new line)"
                                rows="1"
                                required></textarea>
                            <button type="submit" class="send-button">
                                <i class="fas fa-paper-plane"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
    <script src="js/dashboard.js"></script>
    <script src="js/chat.js"></script>
</body>
</html>