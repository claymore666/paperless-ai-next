<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<%- include('partials/shell/head-start', { pageTitle: 'Paperless-AI next Dashboard' }) %>
    <script src="/vendor/chart/chart.min.js"></script>
<%- include('partials/shell/head-end') %>
<%- include('partials/shell/body-open', {
    version: typeof version !== 'undefined' ? version : '',
    chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : false,
    ragEnabled: typeof ragEnabled !== 'undefined' ? ragEnabled : false
}) %>
            <div class="content-wrapper">
                <div class="content-header flex items-center justify-between">
                    <h2 class="content-title">Dashboard Overview</h2>
                    <div class="flex items-center gap-4">
                        <div id="updateNotification" class="hidden fixed bottom-4 right-4 z-50">
                            <a href="https://github.com/admonstrator/paperless-ai-next/releases/" target="_blank" 
                               class="group flex items-center gap-3 bg-white px-4 py-3 rounded-xl shadow-lg border border-gray-100 hover:shadow-xl transition-all duration-300">
                                <div class="flex items-center justify-center w-8 h-8 bg-blue-100 rounded-lg">
                                    <i class="fas fa-arrow-up text-blue-500"></i>
                                </div>
                                <div class="flex flex-col">
                                    <span class="text-sm font-medium text-gray-900">Update Available</span>
                                    <span class="text-xs text-gray-500">Click to download version <span id="latestVersion"></span></span>
                                </div>
                                <i class="fas fa-chevron-right text-gray-400 group-hover:text-gray-600 group-hover:transform group-hover:translate-x-1 transition-all duration-300"></i>
                            </a>
                        </div>
                        <button 
                            id="scanButton" 
                            class="flex items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded-lg transition-colors"
                            onclick="triggerScan()"
                        >
                            <i class="fas fa-sync-alt"></i>
                            <span>Scan Now</span>
                        </button>
                        <!-- Success message toast -->
                        <div id="successToast" class="hidden fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg transition-opacity">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-check"></i>
                                <span>Scan completed successfully!</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="dashboardLoadingBlock" class="material-card mb-6" role="status" aria-live="polite" aria-busy="true">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-spinner fa-spin text-blue-500 text-xl" aria-hidden="true"></i>
                        <div>
                            <div class="font-medium">Loading dashboard data...</div>
                            <div class="text-sm text-gray-600">Fetching latest statistics and charts.</div>
                        </div>
                    </div>
                </div>

                <!-- Top Cards -->
                <div class="card-grid">
                    <!-- Document Chart -->
                    <div class="material-card col-span-2">
                        <h3 class="card-title">Document Processing Status</h3>
                        <div class="flex items-center">
                            <div class="w-1/2 relative">
                                <canvas id="documentChart" height="200"></canvas>
                                <div id="documentChartSkeleton" data-dashboard-chart-skeleton class="absolute inset-0 bg-white/85 dark:bg-slate-900/85 flex items-center justify-center rounded" aria-hidden="false">
                                    <div class="w-32 h-32 rounded-full border-8 border-gray-200 border-t-gray-300 animate-pulse"></div>
                                </div>
                            </div>
                            <div class="w-1/2 pl-6">
                                <div class="stats-legend">
                                    <div class="stat-item">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center">
                                                <div class="w-3 h-3 rounded-full bg-blue-500 mr-2"></div>
                                                <span>AI Processed</span>
                                            </div>
                                            <span id="processedCountValue" class="font-semibold hidden" data-dashboard-value></span>
                                            <span id="processedCountValueSkeleton" class="inline-block h-5 w-12 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                        </div>
                                    </div>
                                    <div class="stat-item mt-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center">
                                                <div class="w-3 h-3 rounded-full bg-amber-400 mr-2"></div>
                                                <span>OCR Needed</span>
                                            </div>
                                            <span id="ocrNeededCountValue" class="font-semibold hidden" data-dashboard-value></span>
                                            <span id="ocrNeededCountValueSkeleton" class="inline-block h-5 w-12 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                        </div>
                                    </div>
                                    <div class="stat-item mt-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center">
                                                <div class="w-3 h-3 rounded-full bg-red-400 mr-2"></div>
                                                <span>Failed</span>
                                            </div>
                                            <span id="failedCountValue" class="font-semibold hidden" data-dashboard-value></span>
                                            <span id="failedCountValueSkeleton" class="inline-block h-5 w-12 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                        </div>
                                    </div>
                                    <div class="stat-item mt-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center">
                                                <div class="w-3 h-3 rounded-full bg-gray-200 mr-2"></div>
                                                <span>Unprocessed</span>
                                            </div>
                                            <span id="unprocessedCountValue" class="font-semibold hidden" data-dashboard-value></span>
                                            <span id="unprocessedCountValueSkeleton" class="inline-block h-5 w-12 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                        </div>
                                    </div>
                                    <div class="total-stats mt-6 pt-4 border-t">
                                        <div class="text-sm text-gray-600">Total Documents</div>
                                        <div id="totalDocumentsValue" class="text-2xl font-bold hidden" data-dashboard-value></div>
                                        <div id="totalDocumentsValueSkeleton" class="h-8 w-20 rounded bg-gray-200 animate-pulse mt-1" data-dashboard-skeleton></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Statistics Card -->
                    <div class="material-card">
                        <h3 class="card-title">System Statistics</h3>
                        <div class="space-y-6">
                            <div class="stat-box cursor-pointer hover:shadow-lg transition-all" onclick="showTagDetails()">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center mr-3">
                                            <i class="fas fa-tags text-blue-500"></i>
                                        </div>
                                        <div>
                                            <div class="text-sm text-gray-600">Total Tags</div>
                                            <div id="totalTagsValue" class="text-xl font-bold hidden" data-dashboard-value></div>
                                            <div id="totalTagsValueSkeleton" class="h-7 w-16 rounded bg-gray-200 animate-pulse mt-1" data-dashboard-skeleton></div>
                                        </div>
                                    </div>
                                    <i class="fas fa-chevron-right text-gray-400"></i>
                                </div>
                            </div>
                            <div class="stat-box cursor-pointer hover:shadow-lg transition-all" onclick="showCorrespondentDetails()">
                                <div class="flex items-center justify-between">
                                    <div class="flex items-center">
                                        <div class="w-10 h-10 rounded-lg bg-purple-100 flex items-center justify-center mr-3">
                                            <i class="fas fa-building text-purple-500"></i>
                                        </div>
                                        <div>
                                            <div class="text-sm text-gray-600">Correspondents</div>
                                            <div id="totalCorrespondentsValue" class="text-xl font-bold hidden" data-dashboard-value></div>
                                            <div id="totalCorrespondentsValueSkeleton" class="h-7 w-16 rounded bg-gray-200 animate-pulse mt-1" data-dashboard-skeleton></div>
                                        </div>
                                    </div>
                                    <i class="fas fa-chevron-right text-gray-400"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Modal Template -->
                    <div id="detailsModal" class="modal hidden">
                        <div class="modal-overlay"></div>
                        <div class="modal-container">
                            <div class="modal-header">
                                <h3 class="modal-title"></h3>
                                <button class="modal-close">
                                    <i class="fas fa-times"></i>
                                </button>
                            </div>
                            <div class="modal-content">
                                <div class="modal-loader hidden">
                                    <div class="loader"></div>
                                </div>
                                <div class="modal-data"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Token Usage Card -->
                    <div class="material-card">
                        <h3 class="card-title">AI Token Usage</h3>
                        <div class="space-y-4">
                            <div class="p-4 rounded-lg theme-info-surface">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-sm text-gray-600">Average Token Usage per Document</span>
                                </div>
                                <div class="mt-2 text-sm">
                                    <div class="flex items-center justify-between mb-2">
                                        <span>Prompt Tokens:</span>
                                        <span id="avgPromptTokensValue" class="font-semibold hidden" data-dashboard-value></span>
                                        <span id="avgPromptTokensValueSkeleton" class="inline-block h-5 w-16 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                    </div>
                                    <div class="flex items-center justify-between mb-2">
                                        <span>Completion Tokens:</span>
                                        <span id="avgCompletionTokensValue" class="font-semibold hidden" data-dashboard-value></span>
                                        <span id="avgCompletionTokensValueSkeleton" class="inline-block h-5 w-16 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                    </div>
                                    <div class="flex items-center justify-between pt-2 border-t">
                                        <span class="font-medium">Average Total:</span>
                                        <span id="avgTotalTokensValue" class="font-semibold hidden" data-dashboard-value></span>
                                        <span id="avgTotalTokensValueSkeleton" class="inline-block h-5 w-16 rounded bg-gray-200 animate-pulse" data-dashboard-skeleton></span>
                                    </div>
                                </div>
                            </div>
                            <div class="grid grid-cols-1 gap-4">
                                <div class="p-4 bg-gray-50 rounded-lg">
                                    <div class="flex items-center justify-between">
                                        <div>
                                            <div class="text-sm text-gray-600">Total Tokens Used</div>
                                            <div id="tokensOverallValue" class="text-xl font-bold hidden" data-dashboard-value></div>
                                            <div id="tokensOverallValueSkeleton" class="h-7 w-24 rounded bg-gray-200 animate-pulse mt-1" data-dashboard-skeleton></div>
                                        </div>
                                        <div class="text-right">
                                            <div class="text-sm text-gray-600">Documents Processed</div>
                                            <div id="documentsProcessedValue" class="text-xl font-bold hidden" data-dashboard-value></div>
                                            <div id="documentsProcessedValueSkeleton" class="h-7 w-20 rounded bg-gray-200 animate-pulse mt-1 ml-auto" data-dashboard-skeleton></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-grid mt-6">
                    <!-- Task Runner Status -->
                    <div class="material-card col-span-2">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="card-title mb-0">Task Runner Status</h3>
                            <span id="statusLastUpdated" class="text-sm text-gray-500"></span>
                        </div>

                        <!-- Active Processing Card -->
                        <div class="bg-white rounded-xl border border-gray-100 p-6 mb-4">
                            <div id="processingContainer" class="hidden">
                                <div class="flex items-center gap-4">
                                    <!-- Spinner -->
                                    <div class="relative">
                                        <div class="w-12 h-12 rounded-full border-4 border-blue-100 border-t-blue-500 animate-spin"></div>
                                        <div class="absolute inset-0 flex items-center justify-center">
                                            <i class="fas fa-file text-blue-500 text-sm"></i>
                                        </div>
                                    </div>
                                    <!-- Document Info -->
                                    <div class="flex-1">
                                        <div class="flex items-center gap-2 mb-1">
                                            <span class="font-medium">Processing Document</span>
                                            <span id="currentDocId" class="text-sm theme-pill-info px-2 py-0.5 rounded-full"></span>
                                        </div>
                                        <div id="currentDocTitle" class="text-sm text-gray-600 truncate"></div>
                                    </div>
                                </div>
                            </div>

                            <div id="idleContainer" class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center">
                                    <i class="fas fa-check text-gray-400"></i>
                                </div>
                                <div>
                                    <div class="font-medium">System Idle</div>
                                    <div class="text-sm text-gray-600">Waiting for new documents</div>
                                </div>
                            </div>
                        </div>

                        <!-- Stats Grid -->
                        <div class="grid grid-cols-2 gap-4">
                            <!-- Today's Stats -->
                            <div class="bg-white rounded-xl border border-gray-100 p-4">
                                <div class="text-sm text-gray-600 mb-1">Processed Today</div>
                                <div class="flex items-end gap-2">
                                    <span id="processedToday" class="text-2xl font-bold">0</span>
                                    <span class="text-sm text-gray-500 mb-1">documents</span>
                                </div>
                            </div>

                            <!-- Last Processed -->
                            <div class="bg-white rounded-xl border border-gray-100 p-4">
                                <div class="text-sm text-gray-600 mb-1">Last Processed</div>
                                <div id="lastProcessed" class="text-sm font-medium"></div>
                            </div>
                        </div>
                    </div>
                
                    <!-- Token Distribution Chart -->
                    <div class="material-card">
                        <h3 class="card-title">Token Usage Distribution</h3>
                        <div class="chart-container relative">
                            <canvas id="tokenDistribution"></canvas>
                            <div id="tokenDistributionSkeleton" data-dashboard-chart-skeleton class="absolute inset-0 animate-pulse rounded bg-gray-200/90" aria-hidden="false"></div>
                        </div>
                    </div>
                
                    <!-- Document Types Chart -->
                    <div class="material-card">
                        <h3 class="card-title">Document Type Distribution</h3>
                        <div class="chart-container relative">
                            <canvas id="documentTypes"></canvas>
                            <div id="documentTypesSkeleton" data-dashboard-chart-skeleton class="absolute inset-0 bg-white/85 dark:bg-slate-900/85 flex items-center justify-center rounded" aria-hidden="false">
                                <div class="w-24 h-24 rounded-full border-8 border-gray-200 border-t-gray-300 animate-pulse"></div>
                            </div>
                        </div>
                    </div>
                </div>
        </main>
    </div>
    <div id="dashboardDataPayload" class="hidden" data-version="<%= version %>"><%= JSON.stringify(paperless_data) %></div>
    <%- include('partials/scripts/dashboard-scripts') %>
    <script src="js/dashboard.js"></script>
    <%- include('partials/shell/footer') %>
    <%- include('partials/shell/body-close') %>