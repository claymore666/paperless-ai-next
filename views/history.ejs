<!-- views/history.ejs -->
<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<%- include('partials/shell/head-start', { pageTitle: 'Modified Documents - Paperless-AI' }) %>
    <link rel="stylesheet" href="/vendor/datatables/css/jquery.dataTables.min.css">
    <style>
        .dataTables_wrapper .dataTables_length, 
        .dataTables_wrapper .dataTables_filter {
            margin-bottom: 1rem;
        }
        .dataTables_wrapper .dataTables_info {
            margin-top: 1rem;
        }
        .dataTables_wrapper .dataTables_paginate {
            margin-top: 1rem;
        }
        .highlight-row {
            background-color: rgba(59, 130, 246, 0.1);
        }
        .modal {
            transition: opacity 0.3s ease-in-out;
            opacity: 0;
            pointer-events: none;
        }

        .modal.show {
            opacity: 1;
            pointer-events: auto;
        }

        .modal.hidden {
            display: none;
        }
            </style>
<%- include('partials/shell/head-end') %>
<%- include('partials/shell/body-open', {
    version: typeof version !== 'undefined' ? version : '',
    chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : false,
    ragEnabled: typeof ragEnabled !== 'undefined' ? ragEnabled : false,
    mainClass: 'main-content modified-documents-page'
}) %>
            <div class="content-wrapper">
                <div class="content-header">
                    <div class="content-header-main">
                        <h1 class="content-title">Modified Documents</h1>
                    </div>
                    <div class="content-header-actions toolbar-actions">
                        <button id="selectAllDocsBtn" class="toolbar-btn toolbar-btn--success" title="Select all visible documents">
                            <i class="fas fa-check-square"></i> Select All
                        </button>
                        <button id="deselectAllDocsBtn" class="toolbar-btn toolbar-btn--neutral" title="Deselect all visible documents">
                            <i class="fas fa-square"></i> Deselect All
                        </button>
                        <button id="forceReloadBtn" class="toolbar-btn toolbar-btn--primary" title="Force reload filters (bypass cache)">
                            <i class="fas fa-sync-alt"></i> Force Reload
                        </button>
                        <button id="resetSelectedBtn" class="toolbar-btn toolbar-btn--danger">
                            Reset Selected
                        </button>
                        <button id="resetAllBtn" class="toolbar-btn toolbar-btn--danger">
                            Reset All
                        </button>
                        <span class="text-sm text-gray-500 italic ml-2">
                            <i class="fas fa-info-circle"></i>
                            History is reconciled automatically. To run manually, go to <a href="/settings#troubleshooting" class="underline hover:text-blue-600">Settings &rarr; Troubleshooting</a>.
                        </span>
                    </div>
                </div>

                <!-- Custom Filters -->
                <div class="app-toolbar-filters mb-6">
                    <div class="filter-item">
                        <select id="tagFilter" class="toolbar-input">
                            <option value="">All Tags</option>
                            <% filters.allTags.forEach(function(tag) { %>
                                <option value="<%= tag.id %>"><%= tag.name %></option>
                            <% }); %>
                        </select>
                    </div>
                    
                    <div class="filter-item">
                        <select id="correspondentFilter" class="toolbar-input">
                            <option value="">All Correspondents</option>
                            <% filters.allCorrespondents.forEach(function(corr) { %>
                                <option value="<%= corr %>"><%= corr %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>

                <!-- Loading Indicator -->
                <div id="historyLoadingIndicator" class="material-card mb-6">
                    <div class="text-center py-8">
                        <div class="mb-4">
                            <i class="fas fa-spinner fa-spin text-5xl text-blue-500" aria-label="Loading" role="status"></i>
                        </div>
                        <div class="mb-2 text-xl font-semibold">Loading history...</div>
                        <div id="historyProgressContainer" class="w-full max-w-md mx-auto bg-gray-200 rounded-full h-3 mb-3"
                             role="progressbar"
                             aria-valuemin="0"
                             aria-valuemax="100"
                             aria-valuenow="0"
                             aria-label="Loading progress">
                            <div id="historyLoadProgress" class="bg-blue-500 h-3 rounded-full transition-all duration-300" style="width: 0%"></div>
                        </div>
                        <div id="historyLoadStatus" class="text-sm text-gray-600" aria-live="polite">Preparing to load history data...</div>
                    </div>
                </div>

                <!-- DataTable -->
                <div id="historyTableContainer" class="material-card" style="display: none;">
                    <div class="overflow-x-auto">
                        <table id="historyTable" class="w-full">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="selectAll" class="rounded"></th>
                                    <th>ID</th>
                                    <th>Title</th>
                                    <th>AI Info</th>
                                    <th>Correspondent</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Info Modal: AI Analysis Details -->
    <div id="infoModal" class="modal hidden">
        <div class="modal-overlay"></div>
        <div class="modal-container" style="max-width:680px;width:95%;display:flex;flex-direction:column;">
            <div class="modal-header" style="display:flex;justify-content:space-between;align-items:flex-start;flex-shrink:0;">
                <div>
                    <h3 class="modal-title" id="infoModalTitle">AI Analysis Details</h3>
                    <a id="infoModalLink" href="#" target="_blank" class="text-sm text-blue-500 hover:underline" style="display:none;">
                        <i class="fa-solid fa-arrow-up-right-from-square"></i> Open in Paperless-ngx
                    </a>
                </div>
                <button class="modal-close" id="infoModalClose"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-content" style="flex:1;min-height:0;overflow-y:auto;max-height:none;">
                <!-- Loading State -->
                <div id="infoModalLoading" class="text-center py-8">
                    <i class="fas fa-spinner fa-spin text-4xl text-blue-500 mb-3"></i>
                    <div class="text-gray-600 mt-3">Loading details...</div>
                </div>
                <!-- Content -->
                <div id="infoModalBody" style="display:none;">
                    <!-- Tags Section -->
                    <div class="mb-5">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-tags mr-1"></i> AI-Set Tags
                            <span id="infoModalLiveHint" class="ml-2 text-xs font-normal text-gray-400"></span>
                        </h4>
                        <div id="infoModalTags" class="flex flex-wrap gap-2 mb-2"></div>
                        <div id="infoModalExternalTags" class="flex flex-wrap gap-2"></div>
                    </div>
                    <!-- Correspondent Section -->
                    <div class="mb-5">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-user mr-1"></i> Correspondent
                        </h4>
                        <div id="infoModalCorrespondent" class="text-sm"></div>
                    </div>
                    <!-- Document Classification Section -->
                    <div class="mb-5" id="infoModalClassificationSection">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-folder-open mr-1"></i> Document Classification
                        </h4>
                        <div class="flex flex-wrap gap-3 text-sm">
                            <div>
                                <span class="text-gray-400 text-xs block mb-1">Type</span>
                                <span id="infoModalDocType" class="px-3 py-1 rounded-full theme-pill-info text-xs font-medium">–</span>
                            </div>
                            <div>
                                <span class="text-gray-400 text-xs block mb-1">Language</span>
                                <span id="infoModalLanguage" class="px-3 py-1 rounded-full bg-purple-50 text-purple-700 text-xs font-medium">–</span>
                            </div>
                        </div>
                    </div>
                    <!-- Custom Fields Section -->
                    <div class="mb-5" id="infoModalCustomFieldsSection">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-list-check mr-1"></i> Custom Fields
                        </h4>
                        <div id="infoModalCustomFields" class="text-sm"></div>
                    </div>
                    <!-- Processed At -->
                    <div class="mb-5">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-clock mr-1"></i> Processed At
                        </h4>
                        <div id="infoModalProcessedAt" class="text-sm"></div>
                    </div>
                    <!-- Token Usage -->
                    <div class="mb-2" id="infoModalTokensSection">
                        <h4 class="font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2">
                            <i class="fas fa-coins mr-1"></i> Token Usage
                        </h4>
                        <div id="infoModalTokens" class="flex gap-4 flex-wrap text-sm"></div>
                    </div>
                    <!-- Original State (collapsible) -->
                    <div class="mb-2" id="infoModalOriginalSection" style="display:none;">
                        <button id="infoModalOriginalToggle" class="flex items-center gap-2 font-semibold text-xs uppercase tracking-wide text-gray-500 mb-2 focus:outline-none w-full text-left">
                            <i class="fas fa-chevron-right text-xs transition-transform" id="infoModalOriginalChevron"></i>
                            <i class="fas fa-history mr-1"></i> Original State (before AI)
                        </button>
                        <div id="infoModalOriginalBody" class="hidden">
                            <div id="infoModalOriginalContent" class="text-sm space-y-1"></div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Footer: outside scrollable area so buttons are always visible -->
            <div class="flex justify-end gap-3 px-5 py-4 border-t flex-shrink-0" style="background:var(--card-bg);border-radius:0 0 12px 12px;">
                <button id="infoModalRestoreBtn" class="toolbar-btn toolbar-btn--danger" style="display:none;">
                    <i class="fas fa-rotate-left mr-1"></i> Restore Original
                </button>
                <button id="infoModalRescanBtn" class="toolbar-btn toolbar-btn--warning">
                    <i class="fas fa-rotate-right mr-1"></i> Rescan
                </button>
                <button id="infoModalCloseBtn" class="toolbar-btn toolbar-btn--outline">
                    Close
                </button>
            </div>
        </div>
    </div>

    <!-- Toast Notification -->
    <div id="toastNotification" class="fixed bottom-6 right-6 z-50 hidden" style="z-index:9999;">
        <div id="toastInner" class="bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg flex items-center gap-3">
            <i id="toastIcon" class="fas fa-check-circle"></i>
            <span id="toastMessage">Operation successful</span>
        </div>
    </div>

    <!-- Confirmation Modal for Selected Documents -->
    <div id="confirmModal" class="modal hidden">
        <div class="modal-overlay"></div>
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title">Confirm Reset</h3>
                <button class="modal-close"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-content">
                <p class="mb-4">Are you sure you want to reset the selected documents to their original values? This action cannot be undone.</p>
                <div class="flex justify-end gap-4">
                    <button id="cancelReset" class="toolbar-btn toolbar-btn--outline">Cancel</button>
                    <button id="confirmReset" class="toolbar-btn toolbar-btn--danger">Confirm Reset</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Confirmation Modal for All Documents -->
    <div id="confirmModalAll" class="modal hidden">
        <div class="modal-overlay"></div>
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title">Confirm Reset All</h3>
                <button class="modal-close"><i class="fas fa-times"></i></button>
            </div>
            <div class="modal-content">
                <p class="mb-4">Are you sure you want to reset <b>all</b> documents to their original values? This action cannot be undone.</p>
                <div class="flex justify-end gap-4">
                    <button id="cancelResetAll" class="toolbar-btn toolbar-btn--outline">Cancel</button>
                    <button id="confirmResetAll" class="toolbar-btn toolbar-btn--danger">Confirm Reset</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/vendor/jquery/jquery.min.js"></script>
    <script src="/vendor/datatables/js/jquery.dataTables.min.js"></script>
    <script src="js/history.js"></script>
    <%- include('partials/shell/footer') %>
    <%- include('partials/shell/body-close') %>