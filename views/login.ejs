<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <title>Login - Paperless-AI next</title>
    <link rel="icon" type="image/webp" href="/favicon.webp">
    <script src="/vendor/tailwind/tailwindcss-3.4.16.js"></script>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="css/dashboard.css">
    <link rel="stylesheet" href="/css/login.css">
</head>
<body class="h-full bg-secondary login-page">
    <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme">
        <i class="fas fa-moon"></i>
    </button>

    <div class="login-background" aria-hidden="true">
        <div class="login-glow login-glow-a"></div>
        <div class="login-glow login-glow-b"></div>
        <div class="login-grid"></div>
    </div>

    <main class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8">
        <section class="material-card login-card w-full max-w-md" aria-labelledby="loginTitle">
            <div class="text-center mb-8">
                <div class="flex flex-col items-center justify-center gap-4 mb-6">
                    <img src="/favicon.webp" class="no-invert" alt="Paperless AI next Logo" style="height: 60px;">
                    <h1 class="brand-title text-2xl">Paperless-AI<span class="text-sm font-semibold text-blue-700"> next</span></h1>
                </div>
                <h2 id="loginTitle" class="text-2xl font-bold">
                    <%= mfaRequired ? 'Verify your identity' : 'Welcome back' %>
                </h2>
                <p class="login-subtitle">
                    <%= mfaRequired
                        ? 'Use the authentication code to complete sign in.'
                        : 'Sign in to continue processing your documents with AI.' %>
                </p>
            </div>

            <% const isMfaStep = !!mfaRequired; %>
            <% const prefilledUsername = typeof username === 'string' ? username : ''; %>

            <form class="space-y-6" action="/login" method="POST" id="loginForm" data-login-form>
                <% if (typeof csrfToken !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <input type="hidden" name="mfaStep" id="mfaStep" value="<%= isMfaStep ? '1' : '0' %>">

                <div class="login-step <%= isMfaStep ? '' : 'is-active' %>" data-step="credentials" aria-hidden="<%= isMfaStep ? 'true' : 'false' %>">
                    <div>
                        <label for="username" class="block text-sm font-medium mb-2">Username</label>
                        <input id="username"
                               name="username"
                               type="text"
                               <%= isMfaStep ? '' : 'required' %>
                               class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-accent-primary"
                               placeholder="Enter your username"
                               autocomplete="username"
                               value="<%= prefilledUsername %>">
                    </div>

                    <div>
                        <label for="password" class="block text-sm font-medium mb-2">Password</label>
                        <input id="password"
                               name="password"
                               type="password"
                               <%= isMfaStep ? '' : 'required' %>
                               class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-accent-primary"
                               placeholder="Enter your password"
                               autocomplete="current-password">
                    </div>
                </div>

                <div class="login-step <%= isMfaStep ? 'is-active' : '' %>" data-step="mfa" aria-hidden="<%= isMfaStep ? 'false' : 'true' %>">
                    <div>
                        <label for="mfaToken" class="block text-sm font-medium mb-2">Authentication code</label>
                        <input id="mfaToken"
                               name="mfaToken"
                               type="text"
                               inputmode="numeric"
                               class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-accent-primary"
                               placeholder="Enter code"
                               autocomplete="one-time-code"
                               <%= isMfaStep ? 'required' : '' %>>
                        <p class="mfa-hint">Enter the one-time code from your authenticator app.</p>
                    </div>
                </div>

                <% if (error) { %>
                    <div class="text-sm p-3 rounded-md theme-alert-error border login-alert" role="alert">
                        <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
                        <%= error %>
                    </div>
                <% } %>

                <div class="space-y-3">
                    <button type="submit"
                            class="w-full login-submit flex justify-center items-center gap-2 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200"
                            id="submitButton"
                            data-submit-button>
                        <span class="submit-idle">
                            <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i>
                            <span><%= isMfaStep ? 'Verify and continue' : 'Sign in' %></span>
                        </span>
                        <span class="submit-loading" aria-hidden="true">
                            <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                            <span><%= isMfaStep ? 'Verifying...' : 'Signing in...' %></span>
                        </span>
                    </button>

                    <button type="button" class="login-back-button <%= isMfaStep ? '' : 'hidden' %>" data-back-button>
                        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                        Back to credentials
                    </button>
                </div>
            </form>
        </section>
    </main>

    <%- include('partials/scripts/login-scripts') %>
    <script src="/js/login.js" defer></script>
</body>
</html>