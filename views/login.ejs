<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
    <title>Login - Paperless-AI next</title>
    <link rel="icon" type="image/webp" href="/favicon.webp">
    <script src="/vendor/tailwind/tailwindcss-3.4.16.js"></script>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="css/dashboard.css">
</head>
<body class="h-full bg-secondary">
    <button id="themeToggle" class="theme-toggle">
        <i class="fas fa-moon"></i>
    </button>

    <div class="min-h-screen flex items-center justify-center px-4 sm:px-6 lg:px-8">
        <div class="material-card w-full max-w-md">
            <div class="text-center mb-8">
                <div class="flex flex-col items-center justify-center gap-4 mb-6">
                    <img src="/favicon.webp" class="no-invert" alt="Paperless AI next Logo" style="height: 60px;">
                    <h1 class="brand-title text-2xl">Paperless-AI<span class="text-sm font-semibold text-blue-700"> next</span></h1>
                </div>
                <h2 class="text-xl font-bold">Sign in to your account</h2>
            </div>

            <form class="space-y-6" action="/login" method="POST">
                <% if (typeof csrfToken !== 'undefined') { %>
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <% } %>
                <div>
                    <label for="username" class="block text-sm font-medium mb-2">Username</label>
                    <input id="username" 
                           name="username" 
                           type="text" 
                           required 
                           class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-accent-primary"
                           placeholder="Enter your username">
                </div>

                <div>
                    <label for="password" class="block text-sm font-medium mb-2">Password</label>
                    <input id="password" 
                           name="password" 
                           type="password" 
                           required 
                           class="w-full px-3 py-2 border rounded-md focus:outline-none focus:ring-2 focus:ring-accent-primary"
                           placeholder="Enter your password">
                </div>

                <% if (error) { %>
                    <div class="text-sm text-center p-3 rounded-md theme-alert-error border">
                        <%= error %>
                    </div>
                <% } %>

                <div>
                    <button type="submit" 
                            class="w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200">
                        Sign in
                    </button>
                </div>
            </form>
        </div>
    </div>

    <%- include('partials/scripts/login-scripts') %>
</body>
</html>