        <div class="flex items-center gap-3 mb-4">
            <span class="restart-seal text-4xl" aria-hidden="true">🦭</span>
            <div>
                <h3 class="text-lg font-semibold">Restarting Paperless-AI next</h3>
                <p id="restartOverlayStatus" class="text-sm text-gray-600 dark:text-gray-300">Saving changes and waiting for server health check…</p>
            </div>
        </div>

