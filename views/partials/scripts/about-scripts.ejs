<script>
	document.addEventListener('DOMContentLoaded', () => {
		const openPrefilledIssueBtn = document.getElementById('openPrefilledIssueBtn');
		const copyIssueDiagnosticsBtn = document.getElementById('copyIssueDiagnosticsBtn');
		const issueHelperStatus = document.getElementById('issueHelperStatus');
		const supportInfoPayload = document.getElementById('supportInfoPayload');

		if (!openPrefilledIssueBtn || !supportInfoPayload) {
			return;
		}

		let supportInfo = {};
		try {
			supportInfo = JSON.parse(supportInfoPayload.textContent || '{}');
		} catch (error) {
			console.error('Failed to parse support info payload:', error);
		}

		const browserInfo = `${navigator.userAgent || 'unknown'}`;
		const osGuess = navigator.platform || 'unknown';
		const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || 'UTC';

		const issueParams = new URLSearchParams({
			template: 'bug_report.yml',
			title: '[Bug]: ',
			summary: 'Describe the issue in one sentence',
			steps: '1.\n2.\n3.\n4.',
			expected: 'Describe expected behavior',
			actual: 'Describe actual behavior',
			app_version: supportInfo.appVersion || 'unknown',
			app_commit: supportInfo.commitSha || 'unknown',
			deployment: 'Docker Compose',
			os: 'Linux',
			os_version: `${osGuess}`,
			browser: browserInfo,
			config_notes: `AI_PROVIDER=${supportInfo.aiProvider || 'unknown'}\nRAG_SERVICE_ENABLED=${supportInfo.ragEnabled ? 'true' : 'false'}\nMISTRAL_OCR_ENABLED=${supportInfo.ocrEnabled ? 'yes' : 'no'}`,
			extra: `Node=${supportInfo.nodeVersion || 'unknown'}\nPlatform=${supportInfo.platform || 'unknown'}\nTimezone=${timezone}\nServerTimeUTC=${supportInfo.serverTimeUtc || 'unknown'}`
		});

		openPrefilledIssueBtn.href = `https://github.com/admonstrator/paperless-ai-next/issues/new?${issueParams.toString()}`;

		if (!copyIssueDiagnosticsBtn) {
			return;
		}

		copyIssueDiagnosticsBtn.addEventListener('click', async () => {
			const diagnostics = [
				'Paperless-AI next diagnostics',
				`App Version: ${supportInfo.appVersion || 'unknown'}`,
				`Commit SHA: ${supportInfo.commitSha || 'unknown'}`,
				`Node.js: ${supportInfo.nodeVersion || 'unknown'}`,
				`Platform: ${supportInfo.platform || 'unknown'}`,
				`Environment: ${supportInfo.nodeEnv || 'unknown'}`,
				`AI Provider: ${supportInfo.aiProvider || 'unknown'}`,
				`RAG Enabled: ${supportInfo.ragEnabled ? 'yes' : 'no'}`,
				`Chat Enabled: ${supportInfo.chatEnabled ? 'yes' : 'no'}`,
				`Mistral OCR Enabled: ${supportInfo.ocrEnabled ? 'yes' : 'no'}`,
				`Server Time (UTC): ${supportInfo.serverTimeUtc || 'unknown'}`,
				`Server Timezone: ${supportInfo.timezone || 'unknown'}`,
				`Host Browser: ${browserInfo}`,
				`Client Timezone: ${timezone}`
			].join('\n');

			try {
				await navigator.clipboard.writeText(diagnostics);
				if (issueHelperStatus) {
					issueHelperStatus.textContent = 'Diagnostics copied to clipboard.';
				}
			} catch (error) {
				console.error('Failed to copy diagnostics:', error);
				if (issueHelperStatus) {
					issueHelperStatus.textContent = 'Could not copy diagnostics. Please copy manually.';
				}
			}
		});
	});
</script>
