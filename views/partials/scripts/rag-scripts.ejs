<script>
    // DOM Elements
    const statusIndicator = document.getElementById('status-indicator');
    const statusText = document.getElementById('status-text');
    const apiStatus = document.getElementById('api-status');
    const chatContainer = document.getElementById('chat-container');
    const messageInput = document.getElementById('message-input');
    const sendButton = document.getElementById('send-button');
    const typingIndicator = document.getElementById('typing-indicator');
    const filtersToggle = document.getElementById('filters-toggle');
    const filtersContent = document.getElementById('filters-content');
    const checkUpdatesBtn = document.getElementById('check-updates-btn');
    const startIndexingBtn = document.getElementById('start-indexing-btn');
    const errorMessage = document.getElementById('error-message');
    const dateFrom = document.getElementById('date-from');
    const dateTo = document.getElementById('date-to');
    const correspondent = document.getElementById('correspondent');
    const aiToggle = document.getElementById('ai-toggle');
    const aiModelBadge = document.getElementById('ai-model-badge');
    const aiModelName = document.getElementById('ai-model-name');
    const loadingOverlay = document.getElementById('rag-loading-overlay');
    const loadingTitle = document.getElementById('loading-title');
    const loadingStatus = document.getElementById('loading-status');
    const loadingErrorAction = document.getElementById('loading-error-action');
    const progressBar = document.getElementById('rag-progress-bar');
    const progressText = document.getElementById('rag-progress-text');
    const stepServerIcon = document.getElementById('step-server-icon');
    const stepDataIcon = document.getElementById('step-data-icon');
    const stepChromaIcon = document.getElementById('step-chroma-icon');
    const stepBm25Icon = document.getElementById('step-bm25-icon');
    const stepIndexIcon = document.getElementById('step-index-icon');

    const stepStatusElements = {
        server: document.getElementById('step-server-status'),
        data: document.getElementById('step-data-status'),
        chroma: document.getElementById('step-chroma-status'),
        bm25: document.getElementById('step-bm25-status'),
        index: document.getElementById('step-index-status')
    };

    const stepIcons = {
        server: stepServerIcon,
        data: stepDataIcon,
        chroma: stepChromaIcon,
        bm25: stepBm25Icon,
        index: stepIndexIcon
    };

    // State
    let useAI = localStorage.getItem('useAI') !== 'false';
    let isConnected = false;
    let isReady = false;
    let initializeRequested = false;
    const paperlessPublicUrl = (typeof window.paperlessPublicUrl === 'string' ? window.paperlessPublicUrl : '').replace(/\/$/, '');

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        updateAIToggle();
        autoResizeTextarea();
        messageInput.addEventListener('input', autoResizeTextarea);

        updateStatusBadgesLoading();
        checkStatus();

        sendButton.addEventListener('click', sendMessage);
        messageInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        if (aiToggle) {
            aiToggle.addEventListener('click', () => {
                useAI = !useAI;
                localStorage.setItem('useAI', useAI);
                updateAIToggle();
            });
        }

        filtersToggle.addEventListener('click', () => {
            filtersContent.classList.toggle('hidden');
            const icon = filtersToggle.querySelector('i');
            if (filtersContent.classList.contains('hidden')) {
                icon.className = 'fas fa-chevron-down';
            } else {
                icon.className = 'fas fa-chevron-up';
            }
        });

        checkUpdatesBtn.addEventListener('click', async () => {
            checkUpdatesBtn.disabled = true;
            checkUpdatesBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Checking...';

            try {
                const response = await fetch('/api/rag/index/check');

                if (response.ok) {
                    const data = await response.json();
                    showSystemMessage(`Status: ${data.message}`);
                    isConnected = true;
                    updateStatusIndicator('online', 'Online');
                } else {
                    showError('Error checking status');
                    isConnected = false;
                    updateStatusIndicator('offline', 'Offline');
                    updateStatusBadgesOffline();
                }
            } catch (error) {
                showError(`Connection error: ${error.message}`);
                isConnected = false;
                updateStatusIndicator('offline', 'Offline');
                updateStatusBadgesOffline();
            } finally {
                checkUpdatesBtn.disabled = false;
                checkUpdatesBtn.innerHTML = '<i class="fas fa-sync-alt"></i> Check for Updates';
            }
        });

        startIndexingBtn.addEventListener('click', async () => {
            startIndexingBtn.disabled = true;
            startIndexingBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Starting...';

            try {
                const response = await fetch('/api/rag/index', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        force: true,
                        background: true
                    })
                });

                if (response.ok) {
                    const data = await response.json();
                    showSystemMessage(`Indexing started: ${data.status}`);
                    updateStatusIndicator('indexing', 'Indexing in progress');
                    addStatusBadge(false, 'Indexing', 'In Progress', 'warning');
                    isConnected = true;
                } else {
                    showError('Error starting indexing');
                    isConnected = false;
                    updateStatusIndicator('offline', 'Offline');
                    updateStatusBadgesOffline();
                }
            } catch (error) {
                showError(`Connection error: ${error.message}`);
                isConnected = false;
                updateStatusIndicator('offline', 'Offline');
                updateStatusBadgesOffline();
            } finally {
                startIndexingBtn.disabled = false;
                startIndexingBtn.innerHTML = '<i class="fas fa-database"></i> Start Indexing';
            }
        });

        setInterval(checkStatus, 10000);
    });

    function updateAIToggle() {
        if (!aiToggle) return;
        if (useAI) {
            aiToggle.classList.add('active');
            aiToggle.title = 'Disable AI response';
        } else {
            aiToggle.classList.remove('active');
            aiToggle.title = 'Enable AI response';
        }
    }

    function autoResizeTextarea() {
        messageInput.style.height = 'auto';
        messageInput.style.height = (messageInput.scrollHeight) + 'px';
    }

    function updateLoadingStep(step, status, label) {
        const iconEl = stepIcons[step];
        if (!iconEl) return;

        iconEl.className = `rag-step-icon rag-step-icon--${status}`;

        if (status === 'loading') {
            iconEl.innerHTML = '<i class="fas fa-circle-notch fa-spin text-xs"></i>';
        } else if (status === 'done') {
            iconEl.innerHTML = '<i class="fas fa-check text-xs"></i>';
        } else if (status === 'error') {
            iconEl.innerHTML = '<i class="fas fa-times text-xs"></i>';
        } else {
            iconEl.innerHTML = '<i class="fas fa-clock text-xs"></i>';
        }

        if (stepStatusElements[step] && label) {
            stepStatusElements[step].textContent = label;
        }
    }

    function setProgress(percent, label) {
        const safePercent = Math.max(0, Math.min(100, percent));
        if (progressBar) {
            progressBar.style.width = `${safePercent}%`;
            const track = progressBar.parentElement;
            if (track) {
                track.setAttribute('aria-valuenow', String(Math.round(safePercent)));
            }
        }
        if (progressText) {
            progressText.textContent = label ? `${Math.round(safePercent)}% · ${label}` : `${Math.round(safePercent)}%`;
        }
    }

    function calculateProgress(statusData) {
        let progress = 0;
        if (statusData.server_up) progress = 20;
        if (statusData.data_loaded) progress = 40;
        if (statusData.chroma_ready) progress = 60;
        if (statusData.bm25_ready) progress = 80;
        if (statusData.index_ready) progress = 100;

        if (statusData.indexing_status?.running && progress < 95) {
            progress = Math.min(progress + 10, 95);
        }

        return progress;
    }

    async function maybeStartInitialization(statusData) {
        if (initializeRequested || isReady) return;
        if (!statusData.server_up || statusData.index_ready) return;

        const indexingRunning = Boolean(statusData.indexing_status && statusData.indexing_status.running);
        if (indexingRunning) return;

        initializeRequested = true;
        try {
            await fetch('/api/rag/initialize', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({ force: false })
            });
        } catch (error) {
            console.error('Failed to auto-initialize RAG service:', error);
            initializeRequested = false;
        }
    }

    function updateLoadingFromStatus(statusData) {
        if (!statusData.server_up) {
            updateLoadingStep('server', 'error', 'Not reachable');
            updateLoadingStep('data', 'pending', 'Pending');
            updateLoadingStep('chroma', 'pending', 'Pending');
            updateLoadingStep('bm25', 'pending', 'Pending');
            updateLoadingStep('index', 'pending', 'Pending');
            setProgress(5, 'Waiting for server');
            loadingStatus.textContent = 'Could not connect to the RAG server. Please make sure the service is running.';
            return;
        }

        updateLoadingStep('server', 'done', 'Connected');
        updateLoadingStep('data', statusData.data_loaded ? 'done' : 'loading', statusData.data_loaded ? 'Loaded' : 'Loading');
        updateLoadingStep('chroma', statusData.chroma_ready ? 'done' : (statusData.data_loaded ? 'loading' : 'pending'), statusData.chroma_ready ? 'Ready' : (statusData.data_loaded ? 'Preparing' : 'Pending'));
        updateLoadingStep('bm25', statusData.bm25_ready ? 'done' : (statusData.chroma_ready ? 'loading' : 'pending'), statusData.bm25_ready ? 'Ready' : (statusData.chroma_ready ? 'Building' : 'Pending'));
        updateLoadingStep('index', statusData.index_ready ? 'done' : (statusData.bm25_ready ? 'loading' : 'pending'), statusData.index_ready ? 'Ready' : (statusData.bm25_ready ? 'Finalizing' : 'Pending'));

        const progress = calculateProgress(statusData);
        const backendMessage = statusData.indexing_status?.message;

        if (statusData.index_ready) {
            loadingTitle.textContent = 'RAG Ready';
            loadingStatus.textContent = backendMessage || 'Search index ready.';
            setProgress(100, 'Ready');
            return;
        }

        loadingTitle.textContent = 'RAG Initialization';
        loadingStatus.textContent = backendMessage || 'Preparing search components...';
        setProgress(progress, statusData.indexing_status?.running ? 'Indexing' : 'Initializing');
    }

    function hideLoadingOverlay() {
        if (loadingOverlay) {
            loadingOverlay.classList.add('opacity-0');
            setTimeout(() => {
                loadingOverlay.classList.add('hidden');
            }, 500);
        }
    }

    async function checkStatus() {
        try {
            const response = await fetch('/api/rag/status');
            if (response.ok) {
                const data = await response.json();
                isConnected = true;
                updateStatus(data);

                updateLoadingFromStatus(data);
                await maybeStartInitialization(data);

                if (data.index_ready && !isReady) {
                    isReady = true;
                    setTimeout(hideLoadingOverlay, 400);
                }
            } else {
                handleConnectionError();
            }
        } catch (error) {
            console.error('Error checking status:', error);
            handleConnectionError();
        }
    }

    function handleConnectionError() {
        isConnected = false;
        updateStatusIndicator('offline', 'Offline');
        updateStatusBadgesOffline();
        
        if (!isReady) {
            updateLoadingStep('server', 'error', 'Not reachable');
            updateLoadingStep('data', 'pending', 'Pending');
            updateLoadingStep('chroma', 'pending', 'Pending');
            updateLoadingStep('bm25', 'pending', 'Pending');
            updateLoadingStep('index', 'pending', 'Pending');
            loadingTitle.textContent = "Connection Failed";
            loadingStatus.textContent = "Could not connect to the RAG server. Please make sure the service is running.";
            setProgress(5, 'Waiting for server');
            loadingErrorAction.classList.remove('hidden');
        }
    }

    function updateStatus(statusData) {
        if (statusData.ai_status === 'ok') {
            const modelName = statusData.ai_model.toUpperCase();
            aiModelName.textContent = `AI MODEL: ${modelName}`;
        } else {
            aiModelName.textContent = 'AI: Not available';
        }

        if (!statusData.server_up) {
            updateStatusIndicator('offline', 'Offline');
            updateStatusBadgesOffline();
            return;
        }

        if (statusData.indexing_status && statusData.indexing_status.running) {
            updateStatusIndicator('indexing', 'Indexing in progress');
        } else if (statusData.index_ready) {
            updateStatusIndicator('online', 'Ready');
        } else if (statusData.data_loaded) {
            updateStatusIndicator('indexing', 'Creating index');
        } else {
            updateStatusIndicator('indexing', 'Loading data');
        }

        updateStatusBadges(statusData);
    }

    function updateStatusIndicator(status, text) {
        statusIndicator.className = `status-dot ${status}`;
        statusText.textContent = text;
    }

    function updateStatusBadgesLoading() {
        apiStatus.innerHTML = '';
        addStatusBadge(false, 'Server', 'Connecting...', 'warning');
        addStatusBadge(false, 'Data', 'Pending', 'warning');
        addStatusBadge(false, 'Chroma', 'Pending', 'warning');
        addStatusBadge(false, 'BM25', 'Pending', 'warning');
        addStatusBadge(false, 'Index', 'Pending', 'warning');
    }

    function updateStatusBadgesOffline() {
        apiStatus.innerHTML = '';
        addStatusBadge(false, 'Server', 'Offline', 'error');
        addStatusBadge(false, 'Data', 'Unknown', 'error');
        addStatusBadge(false, 'Chroma', 'Unknown', 'error');
        addStatusBadge(false, 'BM25', 'Unknown', 'error');
        addStatusBadge(false, 'Index', 'Unknown', 'error');
    }

    function updateStatusBadges(statusData) {
        apiStatus.innerHTML = '';

        addStatusBadge(
            statusData.server_up,
            'Server',
            statusData.server_up ? 'Online' : 'Offline'
        );

        if (statusData.data_loaded !== undefined) {
            addStatusBadge(
                statusData.data_loaded,
                'Data',
                statusData.data_loaded ? 'Loaded' : 'Not loaded'
            );
        }

        if (statusData.index_ready !== undefined) {
            addStatusBadge(
                statusData.index_ready,
                'Index',
                statusData.index_ready ? 'Ready' : 'Not ready'
            );
        }

        if (statusData.chroma_ready !== undefined) {
            addStatusBadge(
                statusData.chroma_ready,
                'Chroma',
                statusData.chroma_ready ? 'Ready' : 'Not ready'
            );
        }

        if (statusData.bm25_ready !== undefined) {
            addStatusBadge(
                statusData.bm25_ready,
                'BM25',
                statusData.bm25_ready ? 'Ready' : 'Not ready'
            );
        }

        if (statusData.indexing_status && statusData.indexing_status.running) {
            addStatusBadge(
                false,
                'Indexing',
                'In Progress',
                'warning'
            );
        }

        if (statusData.indexing_status && statusData.indexing_status.message) {
            addStatusBadge(
                true,
                'Task',
                statusData.indexing_status.message,
                'success'
            );
        }

        if (statusData.indexing_status && statusData.indexing_status.documents_count > 0) {
            addStatusBadge(
                true,
                'Documents',
                statusData.indexing_status.documents_count.toString(),
                'success'
            );
        } else if (statusData.indexing_status) {
            addStatusBadge(
                false,
                'Documents',
                statusData.indexing_status.documents_count.toString(),
                'warning'
            );
        }
    }

    function addStatusBadge(isSuccess, label, value, forceStatus = null) {
        const status = forceStatus || (isSuccess ? 'success' : 'error');
        const icon = status === 'success' ? 'check-circle' :
                    status === 'warning' ? 'exclamation-triangle' : 'times-circle';

        const badge = document.createElement('div');
        badge.className = `status-badge ${status}`;
        badge.innerHTML = `
            <i class="fas fa-${icon}"></i>
            <span>${label}: ${value}</span>
        `;
        apiStatus.appendChild(badge);
    }

    function sendMessage() {
        const questionText = messageInput.value.trim();
        if (!questionText) return;

        if (!isConnected) {
            showError('Cannot send message: Server is offline. Please check your connection.');
            return;
        }

        messageInput.value = '';
        messageInput.style.height = 'auto';

        addUserMessage(questionText);
        typingIndicator.classList.remove('hidden');
        errorMessage.classList.add('hidden');

        const fromDate = dateFrom.value;
        const toDate = dateTo.value;
        const correspondentValue = correspondent.value.trim();

        const endpoint = '/api/rag/ask';

        fetch(endpoint, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({
                question: questionText,
                useAI: useAI,
                from_date: fromDate || undefined,
                to_date: toDate || undefined,
                correspondent: correspondentValue || undefined
            })
        })
        .then(response => {
            if (!response.ok) {
                throw new Error(`Server responded with ${response.status}: ${response.statusText}`);
            }
            return response.json();
        })
        .then(data => {
            typingIndicator.classList.add('hidden');
            addAssistantMessage(data.answer, data.sources, data.model);
            isConnected = true;
            updateStatusIndicator('online', 'Online');
        })
        .catch(error => {
            typingIndicator.classList.add('hidden');
            showError(`Error: ${error.message}`);
            isConnected = false;
            updateStatusIndicator('offline', 'Offline');
            updateStatusBadgesOffline();
            setTimeout(checkStatus, 1000);
        });
    }

    function addUserMessage(message) {
        const messageElement = document.createElement('div');
        messageElement.className = 'message user';
        messageElement.textContent = message;
        chatContainer.appendChild(messageElement);
        scrollToBottom();
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function getPaperlessDocumentUrl(source) {
        if (!source || typeof source !== 'object') {
            return '';
        }

        if (typeof source.document_url === 'string' && source.document_url.trim()) {
            return source.document_url.trim();
        }

        const rawDocumentId = source.doc_id ?? source.document_id ?? source.id;
        const documentId = Number.parseInt(rawDocumentId, 10);

        if (!Number.isInteger(documentId) || documentId <= 0 || !paperlessPublicUrl) {
            return '';
        }

        return `${paperlessPublicUrl}/documents/${documentId}/details`;
    }

    function addAssistantMessage(message, sources = [], modelUsed = null) {
        const messageElement = document.createElement('div');
        messageElement.className = 'message assistant';

        let formattedMessage = message.replace(/\n\n/g, '</p><p>').replace(/\n/g, '<br>');
        if (!formattedMessage.startsWith('<p>')) formattedMessage = '<p>' + formattedMessage;
        if (!formattedMessage.endsWith('</p>')) formattedMessage += '</p>';

        let html = `<div class="markdown">${formattedMessage}</div>`;

        if (modelUsed) {
            html += `<div class="rag-model-meta">
                        <i class="fas fa-robot"></i> Answered with ${modelUsed}
                    </div>`;
        }

        if (sources && sources.length > 0) {
            html += `<div class="sources-container">
                        <div class="sources-title">
                            <span>Sources (${sources.length})</span>
                            <button class="sources-toggle" data-expanded="false">
                                Show all <i class="fas fa-chevron-down"></i>
                            </button>
                        </div>
                        <div class="sources-list">`;

            sources.forEach((source, index) => {
                const date = source.date ? new Date(source.date).toLocaleDateString('en-US') : 'Unknown';
                const hidden = index > 0 ? ' hidden' : '';
                const sourceUrl = getPaperlessDocumentUrl(source);
                const safeTitle = escapeHtml(source.title || 'Unknown Title');
                const safeSnippet = escapeHtml(source.snippet || 'No excerpt available');
                const safeCorrespondent = escapeHtml(source.correspondent || 'Unknown Sender');
                const safeDate = escapeHtml(date);
                const sourceLinkHtml = sourceUrl
                    ? `<a href="${escapeHtml(sourceUrl)}" target="_blank" rel="noopener noreferrer" class="source-doc-link">Open document</a>`
                    : '';

                html += `
                    <div class="source${hidden}" data-index="${index}">
                        <div class="source-title">${safeTitle}</div>
                        <p>${safeSnippet}</p>
                        <div class="source-meta">
                            <span>${safeCorrespondent}</span>
                            <span>${safeDate}</span>
                            ${sourceLinkHtml}
                        </div>
                    </div>
                `;
            });

            html += `</div></div>`;
        }

        messageElement.innerHTML = html;
        chatContainer.appendChild(messageElement);

        const toggleBtn = messageElement.querySelector('.sources-toggle');
        if (toggleBtn) {
            toggleBtn.addEventListener('click', () => {
                const sourcesList = messageElement.querySelector('.sources-list');
                const sources = sourcesList.querySelectorAll('.source');
                const isExpanded = toggleBtn.getAttribute('data-expanded') === 'true';

                if (isExpanded) {
                    sources.forEach((source, index) => {
                        if (index > 0) source.classList.add('hidden');
                    });
                    toggleBtn.innerHTML = 'Show all <i class="fas fa-chevron-down"></i>';
                    toggleBtn.setAttribute('data-expanded', 'false');
                } else {
                    sources.forEach(source => source.classList.remove('hidden'));
                    toggleBtn.innerHTML = 'Hide <i class="fas fa-chevron-up"></i>';
                    toggleBtn.setAttribute('data-expanded', 'true');
                }
            });
        }

        scrollToBottom();
    }

    function showSystemMessage(message) {
        const systemMessage = document.createElement('div');
        systemMessage.className = 'system-message';
        systemMessage.textContent = message;
        chatContainer.appendChild(systemMessage);
        scrollToBottom();
    }

    function showError(message) {
        errorMessage.textContent = message;
        errorMessage.classList.remove('hidden');
    }

    function scrollToBottom() {
        chatContainer.scrollTop = chatContainer.scrollHeight;
    }
</script>
