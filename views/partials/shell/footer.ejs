<%
    const routeVersion = typeof version !== 'undefined' ? String(version).trim() : '';
    const globalVersion = typeof appVersion !== 'undefined' ? String(appVersion).trim() : '';
    const footerVersion = routeVersion || globalVersion || 'unknown';

    const routeCommit = typeof commitSha !== 'undefined' ? String(commitSha).trim() : '';
    const globalCommit = typeof appCommitSha !== 'undefined' ? String(appCommitSha).trim() : '';
    const footerCommitSource = routeCommit || globalCommit || 'unknown';
    const footerCommit = String(footerCommitSource).slice(0, 8);
%>
<footer class="fixed bottom-0 left-0 right-0 md:left-[260px] md:right-0 z-30 border-t border-gray-200/40 bg-white/70 dark:bg-slate-900/70 backdrop-blur-sm">
    <div class="px-4 py-2 text-center text-xs text-gray-500/90">
        <span>Paperless-AI next by <a href="https://admon.me" class="hover:underline" target="_blank" rel="noopener noreferrer">admonstrator</a> <%= footerVersion %> (build <%= footerCommit %>)</span>
    </div>
</footer>