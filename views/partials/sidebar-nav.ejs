    <% if (chatEnabled) { %>
        <li><a href="/chat" class="sidebar-link"><i class="fa-solid fa-comment"></i><span>Chat</span></a></li>
        <% } %>
            <% if (ragEnabled) { %>
                <li><a href="/rag" class="sidebar-link"><i class="fa-solid fa-comment"></i><span>RAG Chat</span></a>
                </li>
                <% } %>
                    <li><a href="/playground" class="sidebar-link"><i
                                class="fa-solid fa-flask-vial"></i><span>Playground</span></a></li>
                    <li><a href="/history" class="sidebar-link"><i
                                class="fa-solid fa-clock-rotate-left"></i><span>History</span></a></li>
