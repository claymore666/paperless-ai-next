                    </li>
                    <li><a href="/about" class="sidebar-link"><i
                                class="fa-solid fa-circle-info"></i><span>About</span></a></li>
                    <li><a href="/settings" class="sidebar-link"><i class="fas fa-cog"></i><span>Settings</span></a>
                    </li>
                    <li><a href="/logout" class="sidebar-link"><i
                                class="fa-solid fa-right-from-bracket"></i><span>Logout</span></a></li>
</ul>
<div class="sidebar-footer">
    <button id="themeToggle" type="button" class="shell-theme-toggle sidebar-theme-toggle" aria-label="Toggle theme">
        <i class="fas fa-moon text-sm" id="themeToggleIcon"></i>
    </button>

    <p class="github-support-text">Support me on GitHub</p>

    <div class="sidebar-support-links">
        <a href="https://github.com/admonstrator/paperless-ai-next" class="github-button">
            <span class="star-button">
                <svg class="star-icon" height="16" width="16" viewBox="0 0 16 16">
