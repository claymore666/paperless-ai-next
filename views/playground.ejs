<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<%- include('partials/shell/head-start', { pageTitle: 'Paperless-AI next Documents' }) %>
    <script src="js/playground-analyzer.js" defer></script>
    <style>
        .document-card {
            position: relative;
            transition: all 0.3s ease;
        }
        
        #messageArea {
            position: relative;
            z-index: 100;
        }
        
        #analysisPrompt {
            font-family: monospace;
        }
        
        #analyzeButton:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .thumbnail-skeleton {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: var(--bg-secondary);
            border-radius: 0.5rem;
        }

        .thumbnail-skeleton::after {
            content: '';
            width: 80%;
            height: 80%;
            border-radius: 0.5rem;
            background: linear-gradient(90deg, rgba(148, 163, 184, 0.12) 25%, rgba(148, 163, 184, 0.25) 50%, rgba(148, 163, 184, 0.12) 75%);
            background-size: 200% 100%;
            animation: thumbShimmer 1.2s infinite;
        }

        @keyframes thumbShimmer {
            0% { background-position: 200% 0; }
            100% { background-position: -200% 0; }
        }

        .thumbnail-skeleton.hidden {
            display: none;
        }

        .playground-thumb {
            opacity: 0;
            transition: opacity 0.25s ease;
        }

        .playground-thumb.is-ready {
            opacity: 1;
        }

        img {
            transition: filter 0.3s ease;
        }
    </style>
    <%- include('partials/shell/head-end') %>
    <%- include('partials/shell/body-open', {
        version: typeof version !== 'undefined' ? version : '',
        chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : false,
        ragEnabled: typeof ragEnabled !== 'undefined' ? ragEnabled : false
    }) %>

        <!-- Main Content -->
            <div class="content-wrapper p-6">
            <div class="mb-6">
                <h1 class="text-2xl font-bold mb-4">Documents</h1>
                <!-- Analysis Section -->
                <div class="material-card mb-8">
                    <h2 class="card-title">Document Analysis</h2>
                    <div class="space-y-4">
                        <textarea 
                            id="analysisPrompt"
                            placeholder="Enter your analysis prompt here..."
                            class="toolbar-input"
                            style="min-height: 128px; resize: vertical;"
                        ></textarea>
                        <div id="analysisActions" class="flex flex-wrap items-center gap-2">
                                <button id="analyzeButton" class="toolbar-btn toolbar-btn--primary toolbar-btn--sm">
                                Analyze Documents
                            </button>
                        </div>
                    </div>
                </div>

                <div id="playgroundInitialLoading" class="material-card mb-4" role="status" aria-live="polite" aria-busy="true">
                    <div class="flex items-center gap-3">
                        <i class="fas fa-spinner fa-spin text-blue-500 text-xl" aria-hidden="true"></i>
                        <div>
                            <div class="font-medium">Loading document previews...</div>
                            <div id="playgroundInitialLoadingStatus" class="text-sm text-gray-600">Preparing thumbnail requests...</div>
                        </div>
                    </div>
                </div>

                <!-- Documents Grid -->
                <div id="documentsGridWrapper" class="relative">
                    <div id="playgroundAnalysisOverlay" class="hidden absolute inset-0 z-10 flex items-center justify-center bg-white/75 dark:bg-slate-900/75 rounded-lg" role="status" aria-live="polite" aria-busy="true">
                        <div class="material-card max-w-md w-full mx-4">
                            <div class="flex items-center gap-3">
                                <i class="fas fa-spinner fa-spin text-blue-500 text-xl" aria-hidden="true"></i>
                                <div>
                                    <div id="playgroundAnalysisStatus" class="font-medium">Analyzing documents...</div>
                                    <div class="text-sm text-gray-600">This can take a moment for larger batches.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="grid grid-cols-4 gap-4" id="documentsGrid"></div>
                </div>
            </div>
            </div>
    </div>

    <!-- Modal -->
    <div id="detailsModal" class="modal hidden">
        <div class="modal-overlay"></div>
        <div class="modal-container">
            <div class="modal-header">
                <h3 class="modal-title"></h3>
                <button class="modal-close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-content">
                <div class="modal-loader hidden">
                    <i class="fas fa-spinner fa-spin"></i>
                    Loading...
                </div>
                <div class="modal-data"></div>
            </div>
        </div>
    </div>
    <script src="js/playground.js"></script>
    <%- include('partials/shell/footer') %>
    <%- include('partials/shell/body-close') %>