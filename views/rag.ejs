<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<%- include('partials/shell/head-start', { pageTitle: 'Paperless-AI next RAG' }) %>
    <link rel="stylesheet" href="/css/rag.css">
<%- include('partials/shell/head-end') %>
<%- include('partials/shell/body-open', {
    version: typeof version !== 'undefined' ? version : '',
    chatEnabled: typeof chatEnabled !== 'undefined' ? chatEnabled : true,
    ragEnabled: typeof ragEnabled !== 'undefined' ? ragEnabled : true,
    bodyClass: 'h-full rag-page'
}) %>
            <div class="content-wrapper">
                <div class="content-header">
                    <div class="content-header-main">
                        <h2 class="content-title min-w-0 truncate">RAG Chat</h2>
                    </div>
                    <div class="content-header-actions rag-header-badges">
                        <div class="rag-status-chip flex items-center gap-2 px-3 py-1.5 rounded-lg border shadow-sm">
                            <div class="status-dot offline" id="status-indicator"></div>
                            <span id="status-text" class="rag-status-text text-[10px] font-bold uppercase tracking-wider">Connecting</span>
                        </div>
                        <div id="ai-model-badge" class="rag-model-chip flex items-center gap-2 px-3 py-1.5 rounded-lg border shadow-sm">
                            <i class="fas fa-robot text-blue-500 text-xs"></i>
                            <span id="ai-model-name" class="rag-model-text text-[10px] font-bold uppercase tracking-wider">Loading...</span>
                        </div>
                    </div>
                </div>

                <!-- API Status and Controls -->
                <div class="material-card mb-6">
                    <div class="flex items-center justify-between cursor-pointer" id="filters-toggle">
                        <h3 class="rag-section-title text-sm font-bold flex items-center gap-2 uppercase tracking-wider">
                            <i class="fas fa-server text-blue-500 text-xs"></i>
                            System Status
                        </h3>
                        <i class="fas fa-chevron-down text-gray-400 text-xs transition-transform duration-200"></i>
                    </div>
                    <div id="filters-content" class="rag-filters-content hidden mt-4 pt-4 border-t">
                        <input type="hidden" id="date-from">
                        <input type="hidden" id="date-to">
                        <input type="hidden" id="correspondent">
                        <input type="hidden" id="ai-toggle">

                        <div class="flex flex-wrap gap-2 mb-6" id="api-status">
                            <!-- Status badges populated by script -->
                        </div>

                        <div class="flex gap-3 justify-end">
                            <button class="rag-secondary-button toolbar-btn toolbar-btn--neutral text-xs uppercase" id="check-updates-btn">
                                <i class="fas fa-sync-alt"></i>
                                Check Updates
                            </button>
                            <button class="toolbar-btn toolbar-btn--primary text-xs uppercase shadow-sm" id="start-indexing-btn">
                                <i class="fas fa-database"></i>
                                Start Indexing
                            </button>
                        </div>
                    </div>
                </div>

                <div class="material-card chat-area">
                    <!-- Loading Overlay (Scoped to Chat Area) -->
                    <div id="rag-loading-overlay" class="rag-loading-overlay absolute inset-0 z-50 flex flex-col items-center justify-center backdrop-blur-sm transition-opacity duration-500">
                        <div class="max-w-md w-full p-8 text-center">
                            <div class="mb-6 flex items-center justify-center relative h-16 w-16 mx-auto">
                                <div class="rag-spinner-track absolute inset-0 border-4 rounded-full"></div>
                                <div class="absolute inset-0 border-4 border-blue-500 border-t-transparent rounded-full animate-spin"></div>
                                <div class="relative z-10 text-blue-500">
                                    <i class="fas fa-database"></i>
                                </div>
                            </div>
                            <h2 id="loading-title" class="rag-loading-title text-lg font-bold mb-1">RAG Service</h2>
                            <p id="loading-status" class="rag-loading-status text-xs mb-6 tracking-wide uppercase font-semibold">Initializing search engine...</p>

                            <div class="rag-progress-track" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="RAG startup progress">
                                <div id="rag-progress-bar" class="rag-progress-bar"></div>
                            </div>
                            <div id="rag-progress-text" class="rag-progress-text">0%</div>
                            
                            <div class="space-y-2.5 max-w-[240px] mx-auto">
                                <div class="rag-loading-step flex items-center gap-3 p-2 rounded-lg border">
                                    <div id="step-server-icon" class="rag-step-icon rag-step-icon--loading">
                                        <i class="fas fa-circle-notch fa-spin text-[10px]"></i>
                                    </div>
                                    <div class="rag-step-content">
                                        <span class="rag-step-label text-[10px] font-bold uppercase tracking-wider">Server Connection</span>
                                        <span id="step-server-status" class="rag-step-status">Waiting</span>
                                    </div>
                                </div>
                                <div class="rag-loading-step flex items-center gap-3 p-2 rounded-lg border">
                                    <div id="step-data-icon" class="rag-step-icon rag-step-icon--pending">
                                        <i class="fas fa-clock text-[10px]"></i>
                                    </div>
                                    <div class="rag-step-content">
                                        <span class="rag-step-label text-[10px] font-bold uppercase tracking-wider">Data Loading</span>
                                        <span id="step-data-status" class="rag-step-status">Pending</span>
                                    </div>
                                </div>
                                <div class="rag-loading-step flex items-center gap-3 p-2 rounded-lg border">
                                    <div id="step-chroma-icon" class="rag-step-icon rag-step-icon--pending">
                                        <i class="fas fa-clock text-[10px]"></i>
                                    </div>
                                    <div class="rag-step-content">
                                        <span class="rag-step-label text-[10px] font-bold uppercase tracking-wider">ChromaDB</span>
                                        <span id="step-chroma-status" class="rag-step-status">Pending</span>
                                    </div>
                                </div>
                                <div class="rag-loading-step flex items-center gap-3 p-2 rounded-lg border">
                                    <div id="step-bm25-icon" class="rag-step-icon rag-step-icon--pending">
                                        <i class="fas fa-clock text-[10px]"></i>
                                    </div>
                                    <div class="rag-step-content">
                                        <span class="rag-step-label text-[10px] font-bold uppercase tracking-wider">BM25 Index</span>
                                        <span id="step-bm25-status" class="rag-step-status">Pending</span>
                                    </div>
                                </div>
                                <div class="rag-loading-step flex items-center gap-3 p-2 rounded-lg border">
                                    <div id="step-index-icon" class="rag-step-icon rag-step-icon--pending">
                                        <i class="fas fa-clock text-[10px]"></i>
                                    </div>
                                    <div class="rag-step-content">
                                        <span class="rag-step-label text-[10px] font-bold uppercase tracking-wider">Search Ready</span>
                                        <span id="step-index-status" class="rag-step-status">Pending</span>
                                    </div>
                                </div>
                            </div>

                            <div id="loading-error-action" class="mt-6 hidden">
                                <button onclick="checkStatus()" class="px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white text-[10px] font-bold uppercase tracking-wider rounded-lg transition-colors flex items-center gap-2 mx-auto">
                                    <i class="fas fa-redo"></i>
                                    <span>Try Again</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="chat-container" id="chat-container">
                        <div class="system-message">
                            Welcome to Paperless-AI next RAG Chat! Ask a question about your documents.
                        </div>
                    </div>

                    <div id="error-message" class="hidden mx-6 p-3 mb-3 text-[10px] font-bold uppercase tracking-wider text-red-700 bg-red-100 rounded-lg border border-red-200"></div>

                    <div class="typing-indicator hidden" id="typing-indicator">
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <div class="dot"></div>
                        <span class="ml-1 uppercase font-bold tracking-tighter">Search in progress</span>
                    </div>

                    <div class="input-wrapper">
                        <div class="input-container">
                            <textarea 
                                class="message-input" 
                                id="message-input" 
                                placeholder="Ask a question..." 
                                rows="1"
                                aria-label="Enter message"></textarea>
                            <button class="send-button" id="send-button" aria-label="Send message">
                                <i class="fas fa-paper-plane text-xs"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script>
        window.paperlessPublicUrl = <%- JSON.stringify(typeof paperlessUrl !== 'undefined' ? paperlessUrl : '').replace(/</g, '\\u003c') %>;
    </script>
    <%- include('partials/scripts/rag-scripts') %>
    <%- include('partials/shell/footer') %>
    <%- include('partials/shell/body-close') %>
