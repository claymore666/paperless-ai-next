<!DOCTYPE html>
<html lang="en" class="h-full" data-theme="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paperless-AI next Dashboard</title>
    <link rel="icon" type="image/webp" href="/favicon.webp">
    <script src="/vendor/tailwind/tailwindcss-3.4.16.js"></script>
    <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css">
    <link rel="stylesheet" href="css/dashboard.css">
    <script src="/vendor/chart/chart.min.js"></script>
    <script src="/vendor/popper/popper.min.js"></script>
    <script src="/vendor/tippy/tippy-bundle.umd.min.js"></script>
    <script src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script src="/vendor/sortable/Sortable.min.js"></script>
    <style>
        /* Content Header Dark Mode Fixes */
        .content-header {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        [data-theme="light"] .content-header {
            background-color: var(--bg-primary);
            color: var(--text-primary);
        }

        [data-theme="dark"] .content-header {
            background-color: var(--bg-secondary);
            color: var(--text-primary);
        }

        /* API Key Container Dark Mode Fixes */
        [data-theme="light"] #apiKeyContainer {
            background-color: var(--stat-box-bg);
            color: var(--text-primary);
        }

        [data-theme="dark"] #apiKeyContainer {
            background-color: var(--bg-secondary);
            color: var(--text-primary);
        }

        /* Regenerate Button Dark Mode Fixes */
        [data-theme="dark"] #regenerateBtn {
            background-color: var(--accent-primary);
        }

        [data-theme="dark"] #regenerateBtn:hover {
            background-color: var(--accent-secondary);
        }

        /* Copy Notification Dark Mode Fixes */
        [data-theme="light"] #copyNotification {
            background-color: #ecfdf5;
            border-color: #d1fae5;
            color: #065f46;
        }

        [data-theme="dark"] #copyNotification {
            background-color: rgba(6, 95, 70, 0.2);
            border-color: rgba(6, 95, 70, 0.3);
            color: #34d399;
        }

        /* Content Title Dark Mode Fixes */
        [data-theme="light"] .content-title {
            color: var(--text-primary);
        }

        [data-theme="dark"] .content-title {
            color: var(--text-primary);
        }

        .settings-env-notice {
            border: 1px solid var(--stats-border);
            background-color: var(--token-usage-bg);
            color: var(--text-primary);
        }
    </style>
</head>
<body class="h-full">
    
    
    <button id="themeToggle" class="theme-toggle">
        <i class="fas fa-moon dark:fas fa-sun"></i>
    </button>
    
    <div class="layout-container">
        <button id="mobileMenuButton" class="mobile-menu-button">
            <i class="fas fa-bars"></i>
        </button>
        <!-- Sidebar -->
        <div id="sidebarOverlay" class="sidebar-overlay"></div>
        <aside class="sidebar">
            <div class="sidebar-header">
                <img src="/favicon.webp" class="no-invert" alt="Paperless AI Logo" style="height: 60px;">
                <h1 class="brand-title"><span class="relative inline-block">Paperless-AI<span class="absolute right-0 top-0 translate-x-1/2 -translate-y-1/2 rotate-12 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-semibold bg-blue-100 text-blue-700">next</span></span><small style="display: block;"><%= version %></small></h1>
            </div>

            <nav class="sidebar-nav">
                <%- include('partials/sidebar-nav', { chatEnabled, ragEnabled }) %>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <div class="content-wrapper">
                <div class="content-header flex justify-between items-center px-6 py-4 bg-white dark:bg-gray-800 shadow-sm">
                    <h2 class="content-title text-2xl font-semibold text-gray-800 dark:text-white">Configuration</h2>
                    <div class="relative flex items-center space-x-4">API-KEY:
                        <div id="apiKeyContainer" 
                             class="relative w-48 px-4 py-2 bg-gray-100 dark:bg-gray-700 text-gray-800 dark:text-gray-100 rounded cursor-pointer select-none filter blur-sm hover:blur-none transition-all duration-200 truncate"
                             data-api-key="<%= config.API_KEY %>"
                             title="<%= config.API_KEY %>">
                             <%= config.API_KEY %>
                        </div>
                        <button id="regenerateBtn" 
                                class="px-3 py-2 bg-blue-500 text-white rounded hover:bg-blue-600 dark:hover:bg-blue-700 transition-colors duration-200 flex items-center space-x-2">
                            <i class="fas fa-sync-alt" id="regenerateIcon"></i>
                            <span>Regenerate</span>
                        </button>
                            <div id="copyNotification" 
                                class="absolute right-0 top-0 mt-12 w-64 theme-alert-success border rounded-lg p-3 hidden">
                            <div class="flex items-center">
                                <i class="fas fa-check-circle mr-2"></i>
                                <span>API key copied to clipboard!</span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Main Form Card -->
                <div class="material-card">
                    <% if (success || settingsError) { %>
                        <div class="mb-6 space-y-4">
                            <% if (success) { %>
                                <div class="flex gap-2 p-4 theme-alert-success border rounded-lg">
                                    <i class="fas fa-check-circle mt-1"></i>
                                    <p><%= success %></p>
                                </div>
                            <% } %>
                            
                            <% if (settingsError) { %>
                                <div class="flex gap-2 p-4 theme-alert-error border rounded-lg">
                                    <i class="fas fa-exclamation-triangle mt-1"></i>
                                    <p><%= settingsError %></p>
                                </div>
                            <% } %>
                        </div>
                    <% } %>
                    <form id="setupForm" class="space-y-8">
                        <div class="settings-env-notice rounded-lg px-4 py-3 text-sm">
                            All settings map to runtime Docker environment variables. Every field below shows the linked ENV key and if a restart is required. Current values are preloaded where safe.
                        </div>

                        <div class="tab-navigation border-b border-gray-200">
                            <nav class="flex flex-wrap gap-2" role="tablist">
                                <button type="button" class="settings-tab-button active flex items-center gap-2 px-4 py-3 text-sm font-medium border-b-2 border-blue-500" data-tab="system-tab">
                                    <i class="fas fa-server"></i>
                                    System
                                </button>
                                <button type="button" class="settings-tab-button flex items-center gap-2 px-4 py-3 text-sm font-medium border-b-2 border-transparent" data-tab="ai-tab">
                                    <i class="fas fa-robot"></i>
                                    AI
                                </button>
                                <button type="button" class="settings-tab-button flex items-center gap-2 px-4 py-3 text-sm font-medium border-b-2 border-transparent" data-tab="ocr-tab">
                                    <i class="fas fa-file-invoice"></i>
                                    OCR
                                </button>
                                <button type="button" class="settings-tab-button flex items-center gap-2 px-4 py-3 text-sm font-medium border-b-2 border-transparent" data-tab="troubleshooting-tab">
                                    <i class="fas fa-wrench"></i>
                                    Troubleshooting
                                </button>
                            </nav>
                        </div>

                        <div id="system-tab" class="settings-tab-content space-y-6">
                            <section class="space-y-4">
                                <h3 class="text-lg font-semibold">Connection</h3>
                                <div class="space-y-2">
                                    <label for="paperlessUrl" class="flex items-center gap-2 text-sm font-medium">
                                        Paperless-ngx API URL
                                        <button type="button" class="text-gray-400 hover:text-gray-600 focus:outline-none" id="urlHelp">
                                            <i class="fas fa-circle-question"></i>
                                        </button>
                                    </label>
                                    <input type="text" id="paperlessUrl" name="paperlessUrl" value="<%= config.PAPERLESS_API_URL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="http://your-paperless-instance:8000" required>
                                    <p class="text-xs text-gray-500">ENV: PAPERLESS_API_URL · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label class="text-sm font-medium">Detected Public URL</label>
                                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
                                        <div id="paperlessDetectedUrlValue" class="flex-1 px-3 py-2 border border-gray-200 rounded-lg bg-gray-50 text-sm break-all">Loading…</div>
                                        <button type="button" id="refreshPublicUrlDetection" class="px-3 py-2 border border-gray-300 rounded-lg text-sm hover:bg-gray-50">
                                            <i class="fas fa-rotate mr-1"></i>Refresh
                                        </button>
                                    </div>
                                    <p id="paperlessDetectedUrlMeta" class="text-xs text-gray-500">Checking Paperless API for configured public URL…</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="paperlessPublicUrl" class="text-sm font-medium">Paperless Public URL Override (optional)</label>
                                    <input type="text" id="paperlessPublicUrl" name="paperlessPublicUrl" value="<%= config.PAPERLESS_PUBLIC_URL || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="https://paperless.example.com">
                                    <p class="text-xs text-gray-500">ENV: PAPERLESS_PUBLIC_URL · Leave empty to use auto-detection/fallback</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="paperlessToken" class="text-sm font-medium">API Token</label>
                                    <div class="relative">
                                        <input type="password" id="paperlessToken" name="paperlessToken" value="" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="<%= configuredSecrets.PAPERLESS_API_TOKEN ? 'Configured (leave empty to keep current value)' : 'Enter API token' %>">
                                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" data-input="paperlessToken">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </div>
                                    <p class="text-xs text-gray-500">ENV: PAPERLESS_API_TOKEN · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="paperlessUsername" class="text-sm font-medium">Paperless-ngx Username</label>
                                    <input type="text" id="paperlessUsername" name="paperlessUsername" value="<%= config.PAPERLESS_USERNAME %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                                    <p class="text-xs text-gray-500">ENV: PAPERLESS_USERNAME · Restart required</p>
                                </div>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">Processing</h3>
                                <div class="space-y-2">
                                    <label for="scanInterval" class="text-sm font-medium">Scan Interval (Cron Format)</label>
                                    <input type="text" id="scanInterval" name="scanInterval" value="<%= config.SCAN_INTERVAL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                                    <p class="text-xs text-gray-500">ENV: SCAN_INTERVAL · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="useExistingData" class="text-sm font-medium">Use existing correspondents and tags</label>
                                    <select id="useExistingData" name="useExistingData" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="no" <%= config.USE_EXISTING_DATA === 'no' ? 'selected' : '' %>>No</option>
                                        <option value="yes" <%= config.USE_EXISTING_DATA === 'yes' ? 'selected' : '' %>>Yes</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: USE_EXISTING_DATA · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="showTags" class="text-sm font-medium">Process only specific pre-tagged documents</label>
                                    <select id="showTags" name="showTags" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="no" <%= config.PROCESS_PREDEFINED_DOCUMENTS === 'no' ? 'selected' : '' %>>No</option>
                                        <option value="yes" <%= config.PROCESS_PREDEFINED_DOCUMENTS === 'yes' ? 'selected' : '' %>>Yes</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: PROCESS_PREDEFINED_DOCUMENTS + TAGS · Restart required</p>
                                </div>

                                <div id="tagsInputSection" class="<%= config.PROCESS_PREDEFINED_DOCUMENTS === 'yes' ? '' : 'hidden' %> space-y-2">
                                    <label for="tagInput" class="text-sm font-medium">Tags</label>
                                    <div class="flex gap-2">
                                        <input type="text" id="tagInput" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter a tag and press Enter">
                                        <button type="button" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                            <i class="fas fa-plus mr-2"></i>
                                            Add
                                        </button>
                                    </div>
                                    <div id="tagsContainer" class="flex flex-wrap gap-2 mt-2">
                                        <% if (config.TAGS && Array.isArray(config.TAGS) && config.TAGS.length > 0) { %>
                                            <% config.TAGS.forEach(tag => { %>
                                                <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full flex items-center gap-2">
                                                    <span><%= tag %></span>
                                                    <button type="button" class="hover:text-blue-600"><i class="fas fa-times"></i></button>
                                                </div>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                    <input type="hidden" id="tags" name="tags" value="<%= Array.isArray(config.TAGS) ? config.TAGS.join(',') : '' %>">
                                </div>

                                <div class="space-y-2">
                                    <label for="ignoreTagInput" class="text-sm font-medium">Ignore Tags</label>
                                    <div class="flex gap-2">
                                        <input type="text" id="ignoreTagInput" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter a tag to ignore and press Enter">
                                        <button type="button" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                            <i class="fas fa-plus mr-2"></i>
                                            Add
                                        </button>
                                    </div>
                                    <div id="ignoreTagsContainer" class="flex flex-wrap gap-2 mt-2">
                                        <% if (config.IGNORE_TAGS && Array.isArray(config.IGNORE_TAGS) && config.IGNORE_TAGS.length > 0) { %>
                                            <% config.IGNORE_TAGS.forEach(tag => { %>
                                                <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full flex items-center gap-2">
                                                    <span><%= tag %></span>
                                                    <button type="button" class="hover:text-blue-600"><i class="fas fa-times"></i></button>
                                                </div>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                    <input type="hidden" id="ignoreTags" name="ignoreTags" value="<%= Array.isArray(config.IGNORE_TAGS) ? config.IGNORE_TAGS.join(',') : '' %>">
                                    <p class="text-xs text-gray-500">ENV: IGNORE_TAGS · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="disableAutomaticProcessing" class="text-sm font-medium">Disable automatic processing</label>
                                    <div class="border border-gray-200 shadow-sm rounded-lg hover:border-blue-500 transition-colors duration-200">
                                        <label for="disableAutomaticProcessing" class="flex items-center p-4 cursor-pointer w-full">
                                            <input type="checkbox" id="disableAutomaticProcessing" class="w-5 h-5 text-blue-600 rounded border-gray-300 focus:ring-blue-500" <%= config.DISABLE_AUTOMATIC_PROCESSING === 'yes' ? 'checked' : '' %>>
                                            <div class="ml-3">
                                                <div class="flex items-center text-gray-900 font-medium">
                                                    <i class="fas fa-power-off mr-2 text-blue-500"></i>
                                                    Disable Automatic Processing
                                                </div>
                                                <p class="text-sm text-gray-500 mt-1">If enabled, scans are not processed by AI automatically.</p>
                                            </div>
                                        </label>
                                    </div>
                                    <p class="text-xs text-gray-500">ENV: DISABLE_AUTOMATIC_PROCESSING · Restart required</p>
                                </div>
                            </section>
                        </div>

                        <div id="ai-tab" class="settings-tab-content space-y-6 hidden">
                            <section class="space-y-4">
                                <h3 class="text-lg font-semibold">Provider</h3>
                                <div class="space-y-2">
                                    <label for="aiProvider" class="text-sm font-medium">AI Provider</label>
                                    <select id="aiProvider" name="aiProvider" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="openai" <%= config.AI_PROVIDER === 'openai' ? 'selected' : '' %>>OpenAI (ChatGPT)</option>
                                        <option value="ollama" <%= config.AI_PROVIDER === 'ollama' ? 'selected' : '' %>>Ollama (Local LLM)</option>
                                        <option value="custom" <%= config.AI_PROVIDER === 'custom' ? 'selected' : '' %>>Custom</option>
                                        <option value="azure" <%= config.AI_PROVIDER === 'azure' ? 'selected' : '' %>>Azure</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: AI_PROVIDER · Restart required</p>
                                </div>

                                <div id="openaiSettings" class="space-y-4">
                                    <div class="space-y-2">
                                        <label for="openaiKey" class="text-sm font-medium">OpenAI API Key</label>
                                        <div class="relative">
                                            <input type="password" id="openaiKey" name="openaiKey" value="" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="<%= configuredSecrets.OPENAI_API_KEY ? 'Configured (leave empty to keep current value)' : 'Enter OpenAI API key' %>">
                                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" data-input="openaiKey"><i class="fas fa-eye"></i></button>
                                        </div>
                                        <p class="text-xs text-gray-500">ENV: OPENAI_API_KEY · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="openaiModel" class="text-sm font-medium">OpenAI Model</label>
                                        <select id="openaiModel" name="openaiModel" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                            <option value="gpt-3.5-turbo-0125" <%= config.OPENAI_MODEL === 'gpt-3.5-turbo-0125' ? 'selected' : '' %>>GPT-3.5 Turbo</option>
                                            <option value="gpt-4o" <%= config.OPENAI_MODEL === 'gpt-4o' ? 'selected' : '' %>>GPT-4o</option>
                                            <option value="o3-mini" <%= config.OPENAI_MODEL === 'o3-mini' ? 'selected' : '' %>>o3-mini</option>
                                            <option value="gpt-4o-mini" <%= config.OPENAI_MODEL === 'gpt-4o-mini' ? 'selected' : '' %>>GPT-4o-mini</option>
                                        </select>
                                        <p class="text-xs text-gray-500">ENV: OPENAI_MODEL · Restart required</p>
                                    </div>
                                </div>

                                <div id="ollamaSettings" class="space-y-4 hidden">
                                    <div class="space-y-2">
                                        <label for="ollamaUrl" class="text-sm font-medium">Ollama API URL</label>
                                        <input type="text" id="ollamaUrl" name="ollamaUrl" value="<%= config.OLLAMA_API_URL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: OLLAMA_API_URL · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="ollamaModel" class="text-sm font-medium">Ollama Model</label>
                                        <input type="text" id="ollamaModel" name="ollamaModel" value="<%= config.OLLAMA_MODEL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: OLLAMA_MODEL · Restart required</p>
                                    </div>
                                </div>

                                <div id="customSettings" class="space-y-4 hidden">
                                    <div class="space-y-2">
                                        <label for="customBaseUrl" class="text-sm font-medium">Custom Base URL</label>
                                        <input type="text" id="customBaseUrl" name="customBaseUrl" value="<%= config.CUSTOM_BASE_URL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: CUSTOM_BASE_URL · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="customApiKey" class="text-sm font-medium">Custom API Key</label>
                                        <div class="relative">
                                            <input type="password" id="customApiKey" name="customApiKey" value="" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="<%= configuredSecrets.CUSTOM_API_KEY ? 'Configured (leave empty to keep current value)' : 'Enter Custom API key' %>">
                                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" data-input="customApiKey"><i class="fas fa-eye"></i></button>
                                        </div>
                                        <p class="text-xs text-gray-500">ENV: CUSTOM_API_KEY · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="customModel" class="text-sm font-medium">Custom Model</label>
                                        <input type="text" id="customModel" name="customModel" value="<%= config.CUSTOM_MODEL %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: CUSTOM_MODEL · Restart required</p>
                                    </div>
                                </div>

                                <div id="azureSettings" class="space-y-4 hidden">
                                    <div class="space-y-2">
                                        <label for="azureEndpoint" class="text-sm font-medium">Azure Endpoint</label>
                                        <input type="text" id="azureEndpoint" name="azureEndpoint" value="<%= config.AZURE_ENDPOINT %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: AZURE_ENDPOINT · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="azureApiKey" class="text-sm font-medium">Azure API Key</label>
                                        <div class="relative">
                                            <input type="password" id="azureApiKey" name="azureApiKey" value="" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="<%= configuredSecrets.AZURE_API_KEY ? 'Configured (leave empty to keep current value)' : 'Enter Azure API key' %>">
                                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" data-input="azureApiKey"><i class="fas fa-eye"></i></button>
                                        </div>
                                        <p class="text-xs text-gray-500">ENV: AZURE_API_KEY · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="azureDeploymentName" class="text-sm font-medium">Deployment</label>
                                        <input type="text" id="azureDeploymentName" name="azureDeploymentName" value="<%= config.AZURE_DEPLOYMENT_NAME %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: AZURE_DEPLOYMENT_NAME · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="azureApiVersion" class="text-sm font-medium">API Version</label>
                                        <input type="text" id="azureApiVersion" name="azureApiVersion" value="<%= config.AZURE_API_VERSION %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: AZURE_API_VERSION · Restart required</p>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t pt-4">
                                    <div class="space-y-2">
                                        <label for="tokenLimit" class="text-sm font-medium">Token Limit</label>
                                        <input type="number" id="tokenLimit" name="tokenLimit" value="<%= config.TOKEN_LIMIT %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: TOKEN_LIMIT · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="responseTokens" class="text-sm font-medium">Response Tokens</label>
                                        <input type="number" id="responseTokens" name="responseTokens" value="<%= config.RESPONSE_TOKENS %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: RESPONSE_TOKENS · Restart required</p>
                                    </div>
                                </div>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">AI Behavior</h3>
                                <div class="space-y-2">
                                    <label for="aiProcessedTag" class="text-sm font-medium">Add AI-processed tag to documents</label>
                                    <select id="aiProcessedTag" name="aiProcessedTag" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="no" <%= config.ADD_AI_PROCESSED_TAG === 'no' ? 'selected' : '' %>>No</option>
                                        <option value="yes" <%= config.ADD_AI_PROCESSED_TAG === 'yes' ? 'selected' : '' %>>Yes</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: ADD_AI_PROCESSED_TAG · Restart required</p>
                                </div>
                                <div id="aiTagNameSection" class="<%= config.ADD_AI_PROCESSED_TAG === 'yes' ? '' : 'hidden' %> space-y-2">
                                    <label for="aiTagName" class="text-sm font-medium">AI-processed Tag Name</label>
                                    <input type="text" id="aiTagName" name="aiTagName" value="<%= config.AI_PROCESSED_TAG_NAME || 'ai-processed' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                    <p class="text-xs text-gray-500">ENV: AI_PROCESSED_TAG_NAME · Restart required</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="usePromptTags" class="text-sm font-medium">Use specific tags in prompt</label>
                                    <select id="usePromptTags" name="usePromptTags" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="no" <%= config.USE_PROMPT_TAGS === 'no' ? 'selected' : '' %>>No</option>
                                        <option value="yes" <%= config.USE_PROMPT_TAGS === 'yes' ? 'selected' : '' %>>Yes</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: USE_PROMPT_TAGS + PROMPT_TAGS · Restart required</p>
                                </div>

                                <div id="promptTagsSection" class="<%= config.USE_PROMPT_TAGS === 'yes' ? '' : 'hidden' %> space-y-2">
                                    <label for="promptTagInput" class="text-sm font-medium">Prompt Tags</label>
                                    <div class="flex gap-2">
                                        <input type="text" id="promptTagInput" class="flex-1 px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Enter a tag and press Enter">
                                        <button type="button" class="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2">
                                            <i class="fas fa-plus mr-2"></i>
                                            Add
                                        </button>
                                    </div>
                                    <div id="promptTagsContainer" class="flex flex-wrap gap-2 mt-2">
                                        <% if (config.PROMPT_TAGS && Array.isArray(config.PROMPT_TAGS) && config.PROMPT_TAGS.length > 0) { %>
                                            <% config.PROMPT_TAGS.forEach(tag => { %>
                                                <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded-full flex items-center gap-2">
                                                    <span><%= tag %></span>
                                                    <button type="button" class="hover:text-blue-600"><i class="fas fa-times"></i></button>
                                                </div>
                                            <% }); %>
                                        <% } %>
                                    </div>
                                    <input type="hidden" id="promptTags" name="promptTags" value="<%= Array.isArray(config.PROMPT_TAGS) ? config.PROMPT_TAGS.join(',') : '' %>">
                                </div>

                                <div class="space-y-2">
                                    <label for="systemPrompt" class="text-sm font-medium">Prompt Description</label>
                                    <textarea id="systemPrompt" name="systemPrompt" rows="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="Describe how the AI should analyze your documents..."><%= config.SYSTEM_PROMPT %></textarea>
                                    <button id="systemPromptBtn" type="button" class="inline-flex items-center px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 focus:ring-2 focus:ring-gray-500 focus:ring-offset-2">
                                        <i class="fas fa-lightbulb mr-2"></i>
                                        Example
                                    </button>
                                    <p class="text-xs text-gray-500">ENV: SYSTEM_PROMPT · Restart required</p>
                                </div>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">Restrictions & External API</h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <label for="restrictToExistingTags" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer">
                                        <input type="checkbox" id="restrictToExistingTags" name="restrictToExistingTags" class="w-5 h-5" <%= config.RESTRICT_TO_EXISTING_TAGS === 'yes' ? 'checked' : '' %>>
                                        <span>Restrict to Existing Tags</span>
                                    </label>
                                    <label for="restrictToExistingCorrespondents" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer">
                                        <input type="checkbox" id="restrictToExistingCorrespondents" name="restrictToExistingCorrespondents" class="w-5 h-5" <%= config.RESTRICT_TO_EXISTING_CORRESPONDENTS === 'yes' ? 'checked' : '' %>>
                                        <span>Restrict to Existing Correspondents</span>
                                    </label>
                                    <label for="restrictToExistingDocumentTypes" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer">
                                        <input type="checkbox" id="restrictToExistingDocumentTypes" name="restrictToExistingDocumentTypes" class="w-5 h-5" <%= config.RESTRICT_TO_EXISTING_DOCUMENT_TYPES === 'yes' ? 'checked' : '' %>>
                                        <span>Restrict to Existing Document Types</span>
                                    </label>
                                </div>
                                <p class="text-xs text-gray-500">ENV: RESTRICT_TO_EXISTING_* · Restart required</p>

                                <label for="externalApiEnabled" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer">
                                    <input type="checkbox" id="externalApiEnabled" name="externalApiEnabled" class="w-5 h-5" <%= config.EXTERNAL_API_ENABLED === 'yes' ? 'checked' : '' %>>
                                    <span>Enable External API Integration</span>
                                </label>

                                <div id="externalApiSettings" class="space-y-4 <%= config.EXTERNAL_API_ENABLED === 'yes' ? '' : 'hidden' %>">
                                    <div class="space-y-2">
                                        <label for="externalApiUrl" class="text-sm font-medium">API URL</label>
                                        <input type="text" id="externalApiUrl" name="externalApiUrl" value="<%= config.EXTERNAL_API_URL || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiMethod" class="text-sm font-medium">HTTP Method</label>
                                        <select id="externalApiMethod" name="externalApiMethod" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                            <option value="GET" <%= config.EXTERNAL_API_METHOD === 'GET' ? 'selected' : '' %>>GET</option>
                                            <option value="POST" <%= config.EXTERNAL_API_METHOD === 'POST' ? 'selected' : '' %>>POST</option>
                                            <option value="PUT" <%= config.EXTERNAL_API_METHOD === 'PUT' ? 'selected' : '' %>>PUT</option>
                                        </select>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiHeaders" class="text-sm font-medium">Headers (JSON)</label>
                                        <textarea id="externalApiHeaders" name="externalApiHeaders" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"><%= config.EXTERNAL_API_HEADERS || '' %></textarea>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiBody" class="text-sm font-medium">Request Body (JSON)</label>
                                        <textarea id="externalApiBody" name="externalApiBody" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"><%= config.EXTERNAL_API_BODY || '' %></textarea>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiTimeout" class="text-sm font-medium">Timeout (milliseconds)</label>
                                        <input type="number" id="externalApiTimeout" name="externalApiTimeout" value="<%= config.EXTERNAL_API_TIMEOUT || '5000' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiTransform" class="text-sm font-medium">Transform Path</label>
                                        <textarea id="externalApiTransform" name="externalApiTransform" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500"><%= config.EXTERNAL_API_TRANSFORM || '' %></textarea>
                                    </div>
                                    <p class="text-xs text-gray-500">ENV: EXTERNAL_API_* · Restart required</p>
                                </div>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">AI Function Limits</h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <label for="activateTagging" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer"><input type="checkbox" id="activateTagging" name="activateTagging" class="w-5 h-5" <%= config.ACTIVATE_TAGGING === 'yes' ? 'checked' : '' %>><span>Tags Assignment</span></label>
                                    <label for="activateCorrespondents" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer"><input type="checkbox" id="activateCorrespondents" name="activateCorrespondents" class="w-5 h-5" <%= config.ACTIVATE_CORRESPONDENTS === 'yes' ? 'checked' : '' %>><span>Correspondent Detection</span></label>
                                    <label for="activateDocumentType" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer"><input type="checkbox" id="activateDocumentType" name="activateDocumentType" class="w-5 h-5" <%= config.ACTIVATE_DOCUMENT_TYPE === 'yes' ? 'checked' : '' %>><span>Document Type Classification</span></label>
                                    <label for="activateTitle" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer"><input type="checkbox" id="activateTitle" name="activateTitle" class="w-5 h-5" <%= config.ACTIVATE_TITLE === 'yes' ? 'checked' : '' %>><span>Title Generation</span></label>
                                    <label for="activateCustomFields" class="flex items-center gap-3 border rounded-lg p-3 cursor-pointer"><input type="checkbox" id="activateCustomFields" name="activateCustomFields" class="w-5 h-5" <%= config.ACTIVATE_CUSTOM_FIELDS === 'yes' ? 'checked' : '' %>><span>Custom Fields</span></label>
                                </div>
                                <p class="text-xs text-gray-500">ENV: ACTIVATE_* · Restart required</p>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">Custom Fields</h3>
                                <div id="customFieldsList" class="space-y-2">
                                    <% if (config.CUSTOM_FIELDS && Array.isArray(JSON.parse(config.CUSTOM_FIELDS).custom_fields)) { %>
                                        <% JSON.parse(config.CUSTOM_FIELDS).custom_fields.forEach((field) => { %>
                                            <div class="custom-field-item flex items-center gap-2 p-3 bg-white dark:bg-gray-800 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-blue-500 transition-colors">
                                                <div class="cursor-move text-gray-400"><i class="fas fa-grip-vertical"></i></div>
                                                <div class="flex-1">
                                                    <p class="font-medium text-gray-900 dark:text-gray-100"><%= field.value %></p>
                                                    <p class="text-sm text-gray-500 dark:text-gray-400">Type: <%= field.data_type %> <%= field.data_type === 'monetary' && field.currency ? `(${field.currency})` : '' %></p>
                                                </div>
                                                <button type="button" onclick="removeCustomField(this)" class="text-gray-400 hover:text-red-500 transition-colors"><i class="fas fa-trash"></i></button>
                                            </div>
                                        <% }); %>
                                    <% } %>
                                </div>

                                <div class="grid grid-cols-12 gap-3">
                                    <div class="col-span-5"><input type="text" id="newFieldName" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100" placeholder="Enter field name..."></div>
                                    <div class="col-span-3">
                                        <select id="newFieldType" onchange="toggleCurrencySelect()" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
                                            <option value="string">Text</option>
                                            <option value="float">Number</option>
                                            <option value="integer">Integer</option>
                                            <option value="monetary">Currency</option>
                                            <option value="date">Date</option>
                                            <option value="boolean">Boolean</option>
                                        </select>
                                    </div>
                                    <div class="col-span-2">
                                        <select id="currencyCode" class="hidden w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white dark:bg-gray-800 text-gray-900 dark:text-gray-100">
                                            <option value="EUR">EUR</option>
                                            <option value="USD">USD</option>
                                            <option value="GBP">GBP</option>
                                            <option value="JPY">JPY</option>
                                            <option value="CHF">CHF</option>
                                        </select>
                                    </div>
                                    <div class="col-span-2"><button type="button" onclick="addCustomField()" class="w-full px-4 py-2 bg-blue-500 hover:bg-blue-600 text-white rounded-lg">Add</button></div>
                                </div>
                                <input type="hidden" id="customFieldsJson" name="customFields" value='<%= config.CUSTOM_FIELDS || "{\"custom_fields\":[]}" %>'>
                                <p class="text-xs text-gray-500">ENV: CUSTOM_FIELDS · Restart required</p>
                            </section>
                        </div>

                        <div id="ocr-tab" class="settings-tab-content space-y-6 hidden">
                            <section class="space-y-4">
                                <h3 class="text-lg font-semibold">Mistral OCR</h3>
                                <div class="space-y-2">
                                    <label for="mistralOcrEnabled" class="text-sm font-medium">Enable Mistral OCR fallback</label>
                                    <select id="mistralOcrEnabled" name="mistralOcrEnabled" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <option value="no" <%= config.MISTRAL_OCR_ENABLED === 'no' ? 'selected' : '' %>>No</option>
                                        <option value="yes" <%= config.MISTRAL_OCR_ENABLED === 'yes' ? 'selected' : '' %>>Yes</option>
                                    </select>
                                    <p class="text-xs text-gray-500">ENV: MISTRAL_OCR_ENABLED · Restart required</p>
                                </div>
                                <div class="space-y-2">
                                    <label for="mistralApiKey" class="text-sm font-medium">Mistral API Key</label>
                                    <div class="relative">
                                        <input type="password" id="mistralApiKey" name="mistralApiKey" value="" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="<%= configuredSecrets.MISTRAL_API_KEY ? 'Configured (leave empty to keep current value)' : 'Enter Mistral API key' %>">
                                        <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600" data-input="mistralApiKey"><i class="fas fa-eye"></i></button>
                                    </div>
                                    <p class="text-xs text-gray-500">ENV: MISTRAL_API_KEY · Restart required</p>
                                </div>
                                <div class="space-y-2">
                                    <label for="mistralOcrModel" class="text-sm font-medium">Mistral OCR Model</label>
                                    <input type="text" id="mistralOcrModel" name="mistralOcrModel" value="<%= config.MISTRAL_OCR_MODEL || 'mistral-ocr-latest' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                    <p class="text-xs text-gray-500">ENV: MISTRAL_OCR_MODEL · Restart required</p>
                                </div>
                            </section>
                        </div>

                        <div id="troubleshooting-tab" class="settings-tab-content space-y-6 hidden">
                            <section class="space-y-4">
                                <h3 class="text-lg font-semibold">Caching & RAG</h3>
                                <div class="space-y-2">
                                    <label for="tagCacheTTL" class="text-sm font-medium flex items-center gap-2">
                                        Tag Cache Lifetime (Seconds)
                                        <button type="button" class="text-gray-400 hover:text-gray-600 focus:outline-none" id="tagCacheTTLHelp">
                                            <i class="fas fa-circle-question"></i>
                                        </button>
                                    </label>
                                    <input type="number" id="tagCacheTTL" name="tagCacheTTL" min="60" max="3600" value="<%= config.TAG_CACHE_TTL_SECONDS || 300 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" required>
                                    <p class="text-xs text-gray-500">ENV: TAG_CACHE_TTL_SECONDS · Restart required</p>
                                </div>
                                <button type="button" id="clearTagCacheBtn" class="px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 focus:ring-2 focus:ring-orange-500 focus:ring-offset-2 transition-colors duration-200 flex items-center gap-2">
                                    <i class="fas fa-trash-alt" id="clearCacheIcon"></i>
                                    <span>Clear Tag Cache Now</span>
                                </button>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t pt-4">
                                    <div class="space-y-2">
                                        <label for="ragServiceEnabled" class="text-sm font-medium">Enable RAG service routes</label>
                                        <select id="ragServiceEnabled" name="ragServiceEnabled" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                            <option value="true" <%= config.RAG_SERVICE_ENABLED === 'true' ? 'selected' : '' %>>True</option>
                                            <option value="false" <%= config.RAG_SERVICE_ENABLED === 'false' ? 'selected' : '' %>>False</option>
                                        </select>
                                        <p class="text-xs text-gray-500">ENV: RAG_SERVICE_ENABLED · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="ragServiceUrl" class="text-sm font-medium">RAG Service URL</label>
                                        <input type="text" id="ragServiceUrl" name="ragServiceUrl" value="<%= config.RAG_SERVICE_URL || 'http://localhost:8000' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: RAG_SERVICE_URL · Restart required</p>
                                    </div>
                                </div>
                            </section>

                            <section class="space-y-4 border-t pt-4">
                                <h3 class="text-lg font-semibold">Runtime Controls</h3>
                                <div class="space-y-2">
                                    <p class="text-sm text-gray-600">Reset local runtime overrides to fall back to your container-injected environment values on next restart.</p>
                                    <button type="button" id="resetLocalOverridesBtn" data-runtime-override-keys="<%- JSON.stringify(runtimeOverrideKeys || []).replace(/\"/g, '&quot;') %>" data-runtime-override-details="<%- JSON.stringify(runtimeOverrideDetails || {}).replace(/\"/g, '&quot;') %>" class="px-4 py-2 bg-red-500 text-white rounded-lg hover:bg-red-600 focus:ring-2 focus:ring-red-500 focus:ring-offset-2 transition-colors duration-200 flex items-center gap-2">
                                        <i class="fas fa-rotate-left"></i>
                                        <span>Reset Local Runtime Overrides</span>
                                    </button>
                                    <p class="text-xs text-gray-500">Removes local override file only (`data/runtime-overrides.json`). A container restart is required to apply injected ENV values.</p>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="space-y-2">
                                        <label for="globalRateLimitWindowMs" class="text-sm font-medium">Global rate-limit window (ms)</label>
                                        <input type="number" id="globalRateLimitWindowMs" name="globalRateLimitWindowMs" value="<%= config.GLOBAL_RATE_LIMIT_WINDOW_MS || 900000 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: GLOBAL_RATE_LIMIT_WINDOW_MS · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="globalRateLimitMax" class="text-sm font-medium">Global rate-limit max requests</label>
                                        <input type="number" id="globalRateLimitMax" name="globalRateLimitMax" value="<%= config.GLOBAL_RATE_LIMIT_MAX || 1000 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: GLOBAL_RATE_LIMIT_MAX · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="trustProxy" class="text-sm font-medium">Trust Proxy</label>
                                        <input type="text" id="trustProxy" name="trustProxy" value="<%= config.TRUST_PROXY %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" placeholder="false | true | 1 | loopback">
                                        <p class="text-xs text-gray-500">ENV: TRUST_PROXY · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="minContentLength" class="text-sm font-medium">Minimum content length</label>
                                        <input type="number" id="minContentLength" name="minContentLength" value="<%= config.MIN_CONTENT_LENGTH || 10 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: MIN_CONTENT_LENGTH · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="paperlessAiPort" class="text-sm font-medium">Paperless-AI Port</label>
                                        <input type="number" id="paperlessAiPort" name="paperlessAiPort" value="<%= config.PAPERLESS_AI_PORT || 3000 %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                        <p class="text-xs text-gray-500">ENV: PAPERLESS_AI_PORT · Restart required</p>
                                    </div>
                                    <div class="space-y-2">
                                        <label for="externalApiAllowPrivateIps" class="text-sm font-medium">Allow private IPs for external API</label>
                                        <select id="externalApiAllowPrivateIps" name="externalApiAllowPrivateIps" class="w-full px-3 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500">
                                            <option value="no" <%= config.EXTERNAL_API_ALLOW_PRIVATE_IPS === 'no' ? 'selected' : '' %>>No</option>
                                            <option value="yes" <%= config.EXTERNAL_API_ALLOW_PRIVATE_IPS === 'yes' ? 'selected' : '' %>>Yes</option>
                                        </select>
                                        <p class="text-xs text-gray-500">ENV: EXTERNAL_API_ALLOW_PRIVATE_IPS · Restart required</p>
                                    </div>
                                </div>
                            </section>
                        </div>

                        <div class="border-t pt-6">
                            <button type="submit" class="w-full px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600 focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 flex items-center justify-center gap-2">
                                <i class="fas fa-save"></i>
                                Save Configuration
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>
    <%- include('partials/scripts/settings-scripts') %>
    <script src="js/settings.js"></script>
</body>
</html>
